---
interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const { title, description, ogTitle, ogDescription, ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname.replace(/\/?$/, '/'), Astro.site);
const resolvedOgTitle = ogTitle || title;
const resolvedOgDescription = ogDescription || description;
const ogImageAbsolute = ogImage ? new URL(ogImage, Astro.site).href : undefined;

const organizationSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  'name': 'LeavingAmerica.co',
  'url': 'https://leavingamerica.co',
  'logo': 'https://leavingamerica.co/images/logo.webp',
  'founder': {
    '@type': 'Person',
    'name': 'Marcin Janiak',
    'jobTitle': 'Founder',
    'sameAs': ['https://www.linkedin.com/in/YOUR-LINKEDIN-SLUG']
  }
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    {ogImageAbsolute && <meta property="og:image" content={ogImageAbsolute} />}
    <meta name="twitter:card" content={ogImageAbsolute ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    {ogImageAbsolute && <meta name="twitter:image" content={ogImageAbsolute} />}
    <!-- Enzuzo Cookie Consent (must load before GTM) -->
    <script is:inline src="https://app.enzuzo.com/scripts/cookiebar/f047f71c-76e5-11f1-88d8-2b6663fe3088"></script>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-562JVS3M');</script>
    <!-- End Google Tag Manager -->
    <!-- Google AdSense -->
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8018237779633697" crossorigin="anonymous"></script>
    <!-- End Google AdSense -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flag-icons@7.2.3/css/flag-icons.min.css"/>
    <script type="application/ld+json" set:html={organizationSchema} />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-562JVS3M"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <nav class="nav" id="main-nav">
      <div class="container nav-inner">
        <a href="/" class="nav-logo">
          <img src="/images/logo.webp" alt="LeavingAmerica" height="48" style="display:block;"/>
        </a>

        <div class="nav-links">
          <a href="/#salary-arbitrage" class="nav-link">Salary Arbitrage</a>
          <a href="/country-match" class="nav-link">Country Match</a>
          <a href="/runway/" class="nav-link">Runway</a>
          <a href="/fire" class="nav-link">Retire Abroad</a>
          <a href="/taxes" class="nav-link">Expat Taxes</a>
          <a href="/countries" class="nav-link">Compare Countries</a>
        </div>

        <a href="/#salary-arbitrage" class="btn-pill btn-pill-primary nav-cta">Try It Free</a>

        <button class="hamburger" id="hamburger" aria-label="Open menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
      <div class="mobile-menu-inner">
        <a href="/#salary-arbitrage" class="mobile-nav-link">Salary Arbitrage</a>
        <a href="/country-match" class="mobile-nav-link">Country Match</a>
        <a href="/runway/" class="mobile-nav-link">Runway Calculator</a>
        <a href="/fire" class="mobile-nav-link">Retire Abroad</a>
        <a href="/taxes" class="mobile-nav-link">Expat Taxes</a>
        <a href="/countries" class="mobile-nav-link">Compare Countries</a>
        <a href="/#salary-arbitrage" class="btn-pill btn-pill-primary mobile-nav-cta">Try It Free →</a>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-container">
        <div class="footer-main">
          <div class="footer-brand">
            <img src="/images/logo2.webp" alt="LeavingAmerica" height="32" style="display:block; margin-bottom:14px"/>
            <p class="footer-tagline">Free salary, retirement, and tax tools for Americans exploring life abroad.</p>
            <p class="footer-affiliate-note">
              Some links earn us a commission at no extra cost to you.
              <a href="/affiliate-disclosure">Disclosure →</a>
            </p>
          </div>
          <div class="footer-col">
            <h4 class="footer-heading">Product</h4>
            <ul class="footer-links">
              <li><a href="/#salary-arbitrage">Salary Arbitrage</a></li>
              <li><a href="/country-match">Country Match</a></li>
              <li><a href="/runway/">Runway Calculator</a></li>
              <li><a href="/fire">Retire Abroad</a></li>
              <li><a href="/taxes">US Expat Taxes</a></li>
              <li><a href="/countries">Compare Countries</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4 class="footer-heading">Resources</h4>
            <ul class="footer-links">
              <li><a href="/statistics/americans-moving-abroad/">Statistics & Data</a></li>
              <li><a href="/methodology">Methodology</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/contact">Contact</a></li>
              <li><a href="/#faq">FAQ</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4 class="footer-heading">Legal</h4>
            <ul class="footer-links">
              <li><a href="/privacy">Privacy Policy</a></li>
              <li><a href="/terms">Terms of Service</a></li>
              <li><a href="/cookie-policy">Cookie Policy</a></li>
              <li><a href="/affiliate-disclosure">Affiliate Disclosure</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p class="footer-copyright">&copy; 2026 LeavingAmerica.co. All rights reserved.</p>
          <p class="footer-data-note">Data sources: World Bank, BEA, Global Peace Index, UNDP, OWID, EF EPI, Numbeo and other public datasets. 82 countries covered.</p>
          <p class="footer-legal-note">For educational purposes only. Not financial, tax, or legal advice.</p>
        </div>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('main-nav');
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 20);
      }, { passive: true });

      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');

      hamburger.addEventListener('click', () => {
        const open = hamburger.classList.toggle('open');
        mobileMenu.classList.toggle('open', open);
        document.body.style.overflow = open ? 'hidden' : '';
      });

      document.querySelectorAll('.mobile-nav-link, .mobile-nav-cta').forEach(el => {
        el.addEventListener('click', () => {
          hamburger.classList.remove('open');
          mobileMenu.classList.remove('open');
          document.body.style.overflow = '';
        });
      });

      if (document.getElementById('fire-config')) {
        var s = document.createElement('script');
        s.src = '/fire-calc.js';
        document.body.appendChild(s);
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg-base: #ffffff;
    --bg-alt: #f8fafc;
    --border: #e2e8f0;
    --text-main: #0f172a;
    --text-muted: #475569;
    --accent: #2563eb;
    --accent-hover: #1d4ed8;
    --success: #16a34a;
    --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.08);
    --transition: all 0.3s ease;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    font-family: 'Manrope', sans-serif;
    background: white;
    color: #0f172a;
    scroll-behavior: smooth;
    overflow-x: clip;
  }

  .container { max-width: 1280px; margin: auto; padding: 0 40px; }

  .btn-pill {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    font-family: 'Manrope', sans-serif;
  }

  .btn-pill-primary { background: #2563eb; color: white; }
  .btn-pill-primary:hover { background: #1d4ed8; transform: translateY(-1px); }

  .footer-link,
  .footer-link:focus,
  .footer-link:focus-visible,
  .footer-link:active {
    outline: none !important;
    box-shadow: none !important;
    background: transparent !important;
    -webkit-tap-highlight-color: transparent;
  }

  .nav-cta { outline: none !important; box-shadow: none !important; }

  .nav-cta:focus,
  .nav-cta:focus-visible,
  a.nav-cta:focus,
  a.nav-cta:focus-visible {
    outline: none !important;
    box-shadow: none !important;
    border: none !important;
  }

  .white-card { background: white; border-radius: 12px; box-shadow: var(--shadow-card); padding: 40px; }

  .section-alt { background: #f8fafc; }
  .section-white { background: #ffffff; }

  section { padding: 100px 0; }

  a { text-decoration: none; color: inherit; }

  /* ── INFO PAGES (about, methodology, legal, contact) ── */
  .ip-page {
    min-height: calc(100vh - 80px);
    background: #ffffff;
  }
  .ip-header {
    background: #F8FAFC;
    border-bottom: 1px solid #E2E8F0;
    padding: 80px 40px 72px;
  }
  .ip-wrap {
    max-width: 960px;
    margin: 0 auto;
  }
  .ip-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #2563EB;
    margin-bottom: 20px;
  }
  .ip-title {
    font-size: 48px;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -1.5px;
    color: #0F172A;
    font-family: 'Manrope', sans-serif;
    margin-bottom: 24px;
  }
  .ip-lead {
    font-size: 20px;
    line-height: 1.75;
    color: #475569;
    max-width: 720px;
    margin-bottom: 28px;
  }
  .ip-date {
    font-size: 13px;
    color: #94A3B8;
    font-weight: 500;
  }
  .ip-body {
    padding: 72px 40px 120px;
  }
  .ip-body h2 {
    font-size: 26px;
    font-weight: 700;
    color: #0F172A;
    font-family: 'Manrope', sans-serif;
    letter-spacing: -0.3px;
    margin-top: 56px;
    margin-bottom: 16px;
    padding-top: 56px;
    border-top: 1px solid #F1F5F9;
  }
  .ip-body h2:first-child {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  .ip-body h3 {
    font-size: 17px;
    font-weight: 700;
    color: #1E293B;
    font-family: 'Manrope', sans-serif;
    margin-top: 32px;
    margin-bottom: 10px;
  }
  .ip-body p {
    font-size: 17px;
    color: #475569;
    line-height: 1.85;
    margin-bottom: 20px;
  }
  .ip-body ul,
  .ip-body ol {
    margin: 4px 0 20px 24px;
  }
  .ip-body li {
    font-size: 17px;
    color: #475569;
    line-height: 1.8;
    margin-bottom: 8px;
  }
  .ip-body a {
    color: #2563EB;
    text-decoration: none;
    border-bottom: 1px solid rgba(37,99,235,0.2);
    transition: border-color 0.15s;
  }
  .ip-body a:hover {
    border-color: #2563EB;
  }
  .ip-body strong {
    color: #1E293B;
    font-weight: 600;
  }
  @media (max-width: 768px) {
    .ip-header { padding: 56px 24px 48px; }
    .ip-body { padding: 40px 24px 80px; }
    .ip-title { font-size: 34px; letter-spacing: -0.5px; }
    .ip-lead { font-size: 17px; }
    .ip-body h2 { font-size: 22px; padding-top: 40px; margin-top: 40px; }
    .ip-body h3 { font-size: 16px; }
    .ip-body p, .ip-body li { font-size: 16px; }
  }
</style>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: rgba(255, 255, 255, 1);
    border-bottom: 1px solid var(--border);
    z-index: 1000;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .nav.scrolled {
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: rgba(226, 232, 240, 0.5);
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.08);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    height: 100%;
    gap: 40px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--accent);
    border-radius: 8px;
    font-size: 18px;
    color: white;
    line-height: 1;
  }

  .nav-logo-wordmark { font-size: 17px; color: var(--text-main); }
  .nav-logo-leaving { font-weight: 400; }
  .nav-logo-america { font-weight: 700; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-left: auto;
  }

  .nav-link {
    font-size: 13px;
    font-weight: 500;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    text-decoration: none;
    transition: var(--transition);
  }

  .nav-link:hover { color: var(--accent); }

  .nav-cta { margin-left: 8px; }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: auto;
    width: 40px;
    height: 40px;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #0f172a;
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    bottom: 0;
    background: white;
    z-index: 999;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu.open { transform: translateX(0); }

  .mobile-menu-inner {
    padding: 32px 40px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-nav-link {
    display: block;
    font-size: 18px;
    font-weight: 500;
    color: #475569;
    padding: 14px 0;
    border-bottom: 1px solid #f1f5f9;
    text-decoration: none;
    transition: color 0.2s;
  }

  .mobile-nav-link:hover { color: var(--accent); }

  .mobile-nav-cta { margin-top: 24px; align-self: flex-start; }

  main { margin-top: 80px; }

  /* ── FOOTER ── */
  .footer {
    background: #0F172A;
    padding: 56px 24px 36px;
  }
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .footer-main {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 32px;
  }
  .footer-tagline {
    font-size: 13px;
    color: #64748B;
    line-height: 1.65;
    margin-bottom: 10px;
  }
  .footer-affiliate-note {
    font-size: 11px;
    color: #475569;
    line-height: 1.5;
  }
  .footer-affiliate-note a {
    color: #64748B;
    text-decoration: none;
  }
  .footer-affiliate-note a:hover {
    color: #94A3B8;
  }
  .footer-heading {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #94A3B8;
    margin-bottom: 16px;
  }
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-links a {
    font-size: 13px;
    color: #64748B;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-links a:hover {
    color: #CBD5E1;
  }
  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 5px;
  }
  .footer-copyright {
    font-size: 12px;
    color: #64748B;
    margin-bottom: 2px;
  }
  .footer-data-note {
    font-size: 11px;
    color: #475569;
    line-height: 1.5;
  }
  .footer-legal-note {
    font-size: 11px;
    color: #475569;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .hamburger { display: flex; }
    .container { padding: 0 24px; }
    section { padding: 60px 0; }
    .footer { padding: 40px 20px 28px; }
    .footer-main { grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 28px; padding-bottom: 28px; }
    .footer-brand { grid-column: 1 / -1; }
    .footer-links a { font-size: 12px; }
    .footer-heading { font-size: 9px; }
    .footer-bottom { gap: 6px; }
  }
</style>
