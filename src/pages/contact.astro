---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | LeavingAmerica.co"
  description="Contact LeavingAmerica.co. Get in touch with questions, data corrections, or partnership inquiries."
>
<div class="ip-page">

  <div class="ip-header">
    <div class="ip-wrap">
      <span class="ip-label">Contact</span>
      <h1 class="ip-title">Contact</h1>
      <p class="ip-lead">LeavingAmerica.co is an independent website focused on purchasing power, cost-of-living, and relocation research for Americans considering life abroad. Questions, feedback, corrections, partnership inquiries, or advertising opportunities?</p>
      <p class="ip-date">Updated: June 2026</p>
    </div>
  </div>

  <div class="ip-body">
    <div class="ip-wrap">

<p><a href="mailto:contact@leavingamerica.co">contact@leavingamerica.co</a></p>

<h2>Reporting a Data Issue</h2>
<p>If you believe a number on the site is incorrect, include the following in your message so we can review it:</p>
<ul>
  <li>Country name</li>
  <li>Metric (for example: healthcare score or visa days)</li>
  <li>Source you are referencing</li>
  <li>Brief description of the issue</li>
</ul>

    </div>
  </div>

</div>
</BaseLayout>
