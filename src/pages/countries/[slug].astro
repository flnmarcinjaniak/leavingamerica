  text-align: center;
}
.final-cta h2 {
  font-size: 28px;
  font-weight: 800;
  color: white;
  margin-bottom: 12px;
}
.final-cta p {
  font-size: 15px;
  color: #94A3B8;
  margin-bottom: 24px;
}

@media (max-width: 768px) {
  .verdict-bar { grid-template-columns: 1fr 1fr; }
  .reasons-grid { grid-template-columns: 1fr; }
  .budget-grid { grid-template-columns: 1fr; }
  .cities-grid { grid-template-columns: 1fr; }
  .quality-grid { grid-template-columns: 1fr; }
  .similar-grid { grid-template-columns: 1fr; }
  .country-hero h1 { font-size: 28px; }
}
</style>

<div class="country-page">

  <div class="breadcrumb">
    <a href="/">Home</a> / <a href="/countries">Countries</a> / {countryName}
  </div>

  <div class="country-hero">
    {countryIso2 && (
      <span class={`fi fi-${countryIso2} country-hero-flag-icon`}></span>
    )}
    <h1>Moving to {countryName} from the US: Cost, Visa, and Healthcare Guide</h1>
    <p class="country-hero-sub">
      Everything Americans need to know about relocating to {countryName} —
      real cost of living data, visa requirements, healthcare, and taxes,
      based on public economic data.
    </p>
  </div>

  <div class="verdict-bar">
    <div class={`verdict-item ${overallScore.grade === 'A' || overallScore.grade === 'B' ? 'favorable' : overallScore.grade === 'C' ? 'neutral' : 'restricted'}`}>
      <div class="verdict-label">Overall Grade</div>
      <div class="verdict-value">{overallScore.grade} · {overallScore.percent}%</div>
    </div>
    <div class={`verdict-item ${visaInfo.status}`}>
      <div class="verdict-label">Visa (US Passport)</div>
      <div class="verdict-value">{visaInfo.text}</div>
    </div>
    <div class={`verdict-item ${englishInfo.status}`}>
      <div class="verdict-label">English Level</div>
      <div class="verdict-value">{englishInfo.text}</div>
    </div>
    <div class={`verdict-item ${taxInfo.status}`}>
      <div class="verdict-label">Tax System</div>
      <div class="verdict-value">{taxInfo.text}</div>
    </div>
  </div>

  <div class="section">
    <div class="preview-card">
      <div class="preview-card-label">COST OF LIVING SNAPSHOT</div>
      <p class="preview-card-text">
        {data.us_comparison
          ? `Living in ${countryName} is ${data.us_comparison}.`
          : `See how ${countryName} compares to the US.`}
        {data.budget_single && ` A single person spends around $${data.budget_single}/month on average, excluding rent.`}
      </p>
      <a href="/#calculator"
         class="preview-cta"
         onclick={`sessionStorage.setItem('quiz_country', '${slug}')`}>
        See exactly how far YOUR salary goes &rarr;
      </a>
    </div>
  </div>

  {moveReasons.length > 0 && (
    <div class="section">
      <h2 class="section-title">Why Americans Move to {countryName}</h2>
      <p class="section-sub">Based on real, publicly sourced economic and quality-of-life data</p>
      <div class="reasons-grid">
        {moveReasons.map(reason => (
          <div class="reason-card">
            <span class="reason-check">&#10003;</span>
            <span>{reason}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  {concernReasons.length > 0 && (
    <div class="section">
      <h2 class="section-title">Why {countryName} Might Not Be Right for You</h2>
      <p class="section-sub">Honest considerations before you commit</p>
      <div class="reasons-grid">
        {concernReasons.map(reason => (
          <div class="reason-card concern">
            <span class="reason-check concern">!</span>
            <span>{reason}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  {(data.budget_single || data.budget_couple) && (
    <div class="section">
      <h2 class="section-title">Typical Monthly Budget in {countryName}</h2>
      <p class="section-sub">Excluding rent · Based on World Bank ICP and Eurostat data via WhereNext</p>
      <div class="budget-grid">
        {data.budget_single && (
          <div class="budget-card">
            <div class="budget-card-label">Single Person</div>
            <div class="budget-card-value">${data.budget_single}</div>
            <div class="budget-card-sub">per month</div>
          </div>
        )}
        {data.budget_couple && (
          <div class="budget-card">
            <div class="budget-card-label">Couple</div>
            <div class="budget-card-value">${data.budget_couple}</div>
            <div class="budget-card-sub">per month</div>
          </div>
        )}
        {data.cost_index && (
          <div class="budget-card">
            <div class="budget-card-label">Cost Index</div>
            <div class="budget-card-value">{data.cost_index}</div>
            <div class="budget-card-sub">US = 82</div>
          </div>
        )}
      </div>
    </div>
  )}

  {data.affordable_cities && data.affordable_cities.length > 0 && (
    <div class="section">
      <h2 class="section-title">Most Affordable Cities in {countryName}</h2>
      <p class="section-sub">Estimated monthly cost of living by city</p>
      <div class="cities-grid">
        {data.affordable_cities.map(city => (
          <div class="city-card">
            <div class="city-name">{city.name}</div>
            <div class="city-cost">${city.monthly_usd}</div>
            <div class="city-cost-label">per month</div>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="section">
    <h2 class="section-title">Quality of Life in {countryName}</h2>
    <p class="section-sub">8 metrics from independent public data sources</p>
    <div class="quality-grid">
      {metricConfigs.map(m => (
        <div class="quality-item">
          <div class="quality-row">
            <span class="quality-label">{m.label}</span>
            <span class="quality-score">{data[m.key]}/10</span>
          </div>
          <div class="progress-track">
            <div class="progress-bar" style={`width: ${data[m.key] * 10}%`}></div>
          </div>
          {m.raw != null && (
            <div class="quality-raw">{m.raw} {m.unit}</div>
          )}
        </div>
      ))}
    </div>
  </div>

  <div class="section">
    <h2 class="section-title">Healthcare for Americans in {countryName}</h2>
    <p class="section-sub">
      {countryName} rates {data.healthcare}/10 for healthcare quality on the Numbeo Health Care Index.
      US health insurance typically does not cover care abroad — most expats and
      digital nomads use international health insurance instead.
    </p>
    <div class="affiliate-mini">
      <span class="affiliate-mini-text">
        Global health coverage from $45/month — no US address required
      </span>
      <a href="#" class="affiliate-mini-btn" rel="noopener sponsored">
        Get a SafetyWing quote &rarr;
      </a>
    </div>
  </div>

  <div class="section">
    <h2 class="section-title">Visa &amp; Residency in {countryName}</h2>
    <p class="section-sub">
      US passport holders can enter {countryName} {visaInfo.text.toLowerCase()}.
      {data.nomad_visa
        ? ` A digital nomad visa is available for remote workers seeking longer-term residency.`
        : ` There is no dedicated digital nomad visa — explore standard residency or work visa options for longer stays.`}
    </p>
  </div>

  <div class="section">
    <h2 class="section-title">Taxes for Americans in {countryName}</h2>
    <p class="section-sub">
      {countryName} uses a {data.tax_system || 'unknown'} tax system.
      US citizens are required to file US federal taxes regardless of where
      they live. The Foreign Earned Income Exclusion (FEIE) may reduce or
      eliminate US tax liability on foreign-earned income up to a certain
      threshold.
    </p>
    <div class="affiliate-mini">
      <span class="affiliate-mini-text">
        Confused about FEIE and double taxation? Get expert help from
        expat tax specialists.
      </span>
      <a href="#" class="affiliate-mini-btn" rel="noopener sponsored">
        Get tax help &rarr;
      </a>
    </div>
  </div>

  <div class="section">
    <h2 class="section-title">Day to Day Life</h2>
    <p class="section-sub">
      Internet speeds average {data.raw?.internet} Mbps.
      {data.raw?.traffic && ` Commuters spend around ${Math.round(data.raw.traffic)} minutes per year in traffic.`}
      {data.pollution >= 7 ? ' Air quality is generally good.' : ' Air quality varies by region.'}
    </p>
  </div>

  <div class="adsense-block">
    <!-- AdSense unit placeholder -->
  </div>

  <div class="section">
    <h2 class="section-title">Frequently Asked Questions</h2>
    {faqs.map(faq => (
      <div class="faq-item">
        <div class="faq-q">{faq.q}</div>
        <div class="faq-a">{faq.a}</div>
      </div>
    ))}
  </div>

  {similarCountries.length > 0 && (
    <div class="section">
      <h2 class="section-title">Similar Countries to Consider</h2>
      <p class="section-sub">Countries with a comparable cost of living</p>
      <div class="similar-grid">
        {similarCountries.map(c => (
          <a href={`/countries/${c.slug}`} class="similar-card">
            {ISO2[c.slug] && (
              <span class={`fi fi-${ISO2[c.slug]} similar-flag-icon`}></span>
            )}
            <div class="similar-name">{NAMES[c.slug] || c.slug}</div>
            <div class="similar-index">Cost index: {c.data.cost_index}</div>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="section">
    <div class="final-cta">
      <h2>Ready to see your exact numbers?</h2>
      <p>Enter your US city and income to get a personalized comparison for {countryName}</p>
      <a href="/#calculator"
         class="preview-cta"
         onclick={`sessionStorage.setItem('quiz_country', '${slug}')`}>
        Calculate My Savings in {countryName} &rarr;
      </a>
    </div>
  </div>

</div>

</BaseLayout>
