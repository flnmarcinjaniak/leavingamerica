---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Gauge from '../../components/Gauge.astro';
import qualityScoresData from '../../data/quality-scores.json';

export async function getStaticPaths() {
  const countries = qualityScoresData.countries;
  return Object.entries(countries).map(
    ([slug, data]) => ({
      params: { slug },
      props: { slug, data, allCountries: countries }
    })
  );
}

const { slug, data, allCountries } = Astro.props;

const NAMES = {
  'portugal':'Portugal','spain':'Spain','poland':'Poland',
  'mexico':'Mexico','thailand':'Thailand','germany':'Germany',
  'japan':'Japan','croatia':'Croatia',
  'czech-republic':'Czech Republic','hungary':'Hungary',
  'romania':'Romania','bulgaria':'Bulgaria','vietnam':'Vietnam',
  'south-korea':'South Korea','australia':'Australia',
  'new-zealand':'New Zealand','canada':'Canada','ireland':'Ireland',
  'netherlands':'Netherlands','france':'France',
  'argentina':'Argentina','ecuador':'Ecuador','morocco':'Morocco',
  'switzerland':'Switzerland','norway':'Norway','denmark':'Denmark',
  'sweden':'Sweden','belgium':'Belgium','austria':'Austria',
  'finland':'Finland','united-kingdom':'United Kingdom',
  'singapore':'Singapore','united-arab-emirates':'UAE',
  'qatar':'Qatar','saudi-arabia':'Saudi Arabia','iceland':'Iceland',
  'india':'India','philippines':'Philippines','china':'China',
  'georgia':'Georgia','serbia':'Serbia','kenya':'Kenya',
  'peru':'Peru','brazil':'Brazil','chile':'Chile',
  'albania':'Albania','sri-lanka':'Sri Lanka','egypt':'Egypt',
  'indonesia':'Indonesia','colombia':'Colombia',
  'costa-rica':'Costa Rica','panama':'Panama',
  'malaysia':'Malaysia','italy':'Italy','greece':'Greece',
  'bahamas':'Bahamas','belize':'Belize','bolivia':'Bolivia',
  'cambodia':'Cambodia','cyprus':'Cyprus',
  'dominican-republic':'Dominican Republic',
  'el-salvador':'El Salvador','estonia':'Estonia',
  'ghana':'Ghana','honduras':'Honduras','jamaica':'Jamaica',
  'kazakhstan':'Kazakhstan','latvia':'Latvia',
  'lithuania':'Lithuania','malta':'Malta',
  'montenegro':'Montenegro','nepal':'Nepal',
  'nicaragua':'Nicaragua','north-macedonia':'North Macedonia',
  'paraguay':'Paraguay','rwanda':'Rwanda',
  'slovakia':'Slovakia','slovenia':'Slovenia',
  'south-africa':'South Africa','taiwan':'Taiwan',
  'turkey':'Turkey','uruguay':'Uruguay',
};

const ISO2 = {
  'portugal':'pt','spain':'es','poland':'pl','mexico':'mx',
  'thailand':'th','germany':'de','japan':'jp','croatia':'hr',
  'czech-republic':'cz','hungary':'hu','romania':'ro',
  'bulgaria':'bg','vietnam':'vn','south-korea':'kr',
  'australia':'au','new-zealand':'nz','canada':'ca',
  'ireland':'ie','netherlands':'nl','france':'fr',
  'argentina':'ar','ecuador':'ec','morocco':'ma',
  'switzerland':'ch','norway':'no','denmark':'dk',
  'sweden':'se','belgium':'be','austria':'at','finland':'fi',
  'united-kingdom':'gb','singapore':'sg',
  'united-arab-emirates':'ae','qatar':'qa',
  'saudi-arabia':'sa','iceland':'is','india':'in',
  'philippines':'ph','china':'cn','georgia':'ge',
  'serbia':'rs','kenya':'ke','peru':'pe','brazil':'br',
  'chile':'cl','albania':'al','sri-lanka':'lk','egypt':'eg',
  'indonesia':'id','colombia':'co','costa-rica':'cr',
  'panama':'pa','malaysia':'my','italy':'it','greece':'gr',
  'bahamas':'bs','belize':'bz','bolivia':'bo',
  'cambodia':'kh','cyprus':'cy','dominican-republic':'do',
  'el-salvador':'sv','estonia':'ee','ghana':'gh',
  'honduras':'hn','jamaica':'jm','kazakhstan':'kz',
  'latvia':'lv','lithuania':'lt','malta':'mt',
  'montenegro':'me','nepal':'np','nicaragua':'ni',
  'north-macedonia':'mk','paraguay':'py','rwanda':'rw',
  'slovakia':'sk','slovenia':'si','south-africa':'za',
  'taiwan':'tw','turkey':'tr','uruguay':'uy',
};

const countryName = NAMES[slug] || slug;
const countryIso2 = ISO2[slug] || '';

// Affiliate links — replace placeholder codes with your actual affiliate URLs
const AFFILIATE_LINKS: Record<string, string> = {
  'Wise':        'https://wise.com/invite/YOURCODE',
  'NordVPN':     'https://nordvpn.com/?partner=YOURCODE',
  'SafetyWing':  'https://safetywing.com/nomad-insurance/?referenceID=26555621&utm_source=26555621&utm_medium=Ambassador',
  'Airalo':      'https://www.airalo.com?referral=YOURCODE',
};

function linkifyAffiliates(text: string): string {
  let result = text;
  for (const [brand, url] of Object.entries(AFFILIATE_LINKS)) {
    const regex = new RegExp(`\\b${brand}\\b`, 'g');
    result = result.replace(
      regex,
      `<a href="${url}" class="aff-link" target="_blank" rel="noopener sponsored">${brand}</a>`
    );
  }
  return result;
}

function calculateGrade(q) {
  const weights = {
    safety: 0.25, healthcare: 0.20, happiness: 0.15,
    hdi: 0.15, pollution: 0.08, unemployment: 0.07,
    internet: 0.05, traffic: 0.05
  };
  let totalScore = 0, totalWeight = 0;
  for (const [metric, weight] of Object.entries(weights)) {
    const score = q[metric];
    if (score !== null && score !== undefined) {
      totalScore += score * weight;
      totalWeight += weight;
    }
  }
  const weightedAverage = totalWeight > 0
    ? totalScore / totalWeight : 0;
  const percent = Math.round(weightedAverage * 10);
  let label;
  if (percent >= 90) label = 'Outstanding destination';
  else if (percent >= 80) label = 'Excellent destination';
  else if (percent >= 70) label = 'Very good destination';
  else if (percent >= 60) label = 'Good destination';
  else if (percent >= 50) label = 'Moderate destination';
  else if (percent >= 40) label = 'Mixed destination';
  else if (percent >= 30) label = 'Limited destination';
  else label = 'Challenging destination';
  return { percent, label };
}

const overallScore = (data.grade_percent != null && data.grade_label)
  ? { percent: data.grade_percent, label: data.grade_label }
  : calculateGrade(data);

// Quick Verdict Bar helpers
function getVisaStatus(visaDays) {
  if (visaDays === null || visaDays === undefined) {
    return { text: 'Check requirements', status: 'neutral' };
  }
  if (visaDays >= 90) {
    return { text: `Visa-free · ${visaDays} days`, status: 'favorable' };
  }
  if (visaDays >= 30) {
    return { text: `Visa on arrival · ${visaDays} days`, status: 'neutral' };
  }
  return { text: 'Visa required', status: 'restricted' };
}

function getEnglishStatus(english) {
  if (english === null || english === undefined) {
    return { text: 'Data not available', status: 'neutral' };
  }
  if (english >= 999) return { text: 'Native English', status: 'favorable' };
  if (english >= 600) return { text: `Very High (${english})`, status: 'favorable' };
  if (english >= 500) return { text: `High (${english})`, status: 'favorable' };
  if (english >= 400) return { text: `Moderate (${english})`, status: 'neutral' };
  return { text: `Low (${english})`, status: 'restricted' };
}

function getTaxStatus(taxSystem) {
  if (taxSystem === 'zero') return { text: 'No income tax', status: 'favorable' };
  if (taxSystem === 'territorial') return { text: 'Territorial', status: 'favorable' };
  if (taxSystem === 'worldwide') return { text: 'Worldwide', status: 'neutral' };
  return { text: 'Unknown', status: 'neutral' };
}

const visaInfo = getVisaStatus(data.visa_days);
const englishInfo = getEnglishStatus(data.english);
const taxInfo = getTaxStatus(data.tax_system);

// Why Americans Move Here — conditional reasons
const moveReasons = [];
if (data.tax_system === 'zero') {
  moveReasons.push('No personal income tax, which means you keep significantly more of every paycheck');
} else if (data.tax_system === 'territorial') {
  moveReasons.push('Territorial tax system: your foreign-sourced income is generally not taxed locally');
}
if (data.healthcare >= 8) {
  moveReasons.push(`Healthcare rated ${data.healthcare}/10 with quality care at a fraction of US costs`);
}
if (data.safety >= 8) {
  moveReasons.push(`Ranked ${data.safety}/10 for safety, well above the global average`);
}
if (data.nomad_visa) {
  moveReasons.push('Digital Nomad Visa available, giving remote workers a clear legal path to stay long-term');
}
if (data.cost_index && data.cost_index < 60) {
  moveReasons.push(data.us_comparison
    ? `Living costs are ${data.us_comparison}`
    : 'Significantly lower cost of living than the US');
}
if (data.happiness >= 7) {
  moveReasons.push('Consistently ranks among the happiest countries in the world');
}
if (data.english >= 999) {
  moveReasons.push('English is the primary language, so daily life is easy without learning a new one');
} else if (data.english >= 600) {
  moveReasons.push(`Very high English proficiency (${data.english} EF EPI) makes daily life easy`);
}
if (data.internet >= 9) {
  moveReasons.push('Fast, reliable internet that works well for remote work');
}

// Why It Might Not Be Right For You — conditional concerns
const concernReasons = [];
if (data.english !== null && data.english < 999 && data.english < 450) {
  concernReasons.push('Lower English proficiency may mean a real language barrier in daily life');
}
if (data.visa_days !== null && data.visa_days < 90) {
  concernReasons.push('Limited visa-free stay; longer-term residency requires a separate visa application');
}
if (data.tax_system === 'worldwide') {
  concernReasons.push('Worldwide taxation means you may owe local tax in addition to US filing obligations');
}
if (data.unemployment !== null && data.unemployment < 6) {
  concernReasons.push('A more competitive local job market if you plan to seek local employment');
}
if (data.safety !== null && data.safety < 6) {
  concernReasons.push('Safety varies quite a bit by region, so research specific neighborhoods before committing');
}
if (data.healthcare !== null && data.healthcare < 6) {
  concernReasons.push('Healthcare infrastructure may not match what you are used to in major US cities');
}
if (!data.nomad_visa) {
  concernReasons.push('No dedicated digital nomad visa; remote workers need to look into standard residency or work visa options');
}
if (data.cost_index && data.cost_index > 80) {
  concernReasons.push(data.us_comparison
    ? `Living costs are ${data.us_comparison}`
    : 'Cost of living is comparable to or higher than many US cities');
}

if (concernReasons.length < 2) {
  concernReasons.push(
    'No destination is perfect for everyone. ' +
    'Spend time researching specific cities ' +
    'and neighborhoods, and if possible, visit ' +
    'before making a long-term commitment.'
  );
}

// Quality metrics for display
function interpretSafety(score) {
  if (score >= 8) return 'Among the safer countries globally';
  if (score >= 6) return 'Reasonably safe by global standards';
  if (score >= 4) return 'Safety varies significantly by region';
  return 'Requires careful research before relocating';
}
function interpretHealthcare(score) {
  if (score >= 8) return 'Top-tier healthcare infrastructure';
  if (score >= 6) return 'Solid healthcare system overall';
  if (score >= 4) return 'Healthcare quality varies by facility';
  return 'Healthcare infrastructure is limited';
}
function interpretHappiness(score) {
  if (score >= 8) return 'Among the happiest populations globally';
  if (score >= 6) return 'Generally positive quality of life';
  if (score >= 4) return 'Moderate life satisfaction reported';
  return 'Lower reported life satisfaction';
}
function interpretPollution(score) {
  if (score >= 8) return 'Among the cleaner environments globally';
  if (score >= 6) return 'Generally good air quality';
  if (score >= 4) return 'Air quality varies by region and season';
  return 'Pollution is a notable concern';
}
function interpretInternet(score) {
  if (score >= 8) return 'Among the fastest connections worldwide';
  if (score >= 6) return 'Reliable for most remote work needs';
  if (score >= 4) return 'Workable but inconsistent in places';
  return 'May be limiting for remote work';
}
function interpretTraffic(score) {
  if (score >= 8) return 'Minimal time lost to congestion';
  if (score >= 6) return 'Manageable commute times overall';
  if (score >= 4) return 'Congestion is common in major cities';
  return 'Significant time lost to traffic';
}
function interpretUnemployment(score) {
  if (score >= 8) return 'Strong, stable job market';
  if (score >= 6) return 'Generally stable employment conditions';
  if (score >= 4) return 'Job market conditions vary';
  return 'Employment conditions are challenging';
}
function interpretGdpGrowth(score) {
  if (score >= 8) return 'Strong economic growth';
  if (score >= 6) return 'Steady economic expansion';
  if (score >= 4) return 'Modest or mixed economic growth';
  return 'Economic growth has been limited';
}
function interpretHdi(score) {
  if (score >= 8) return 'Very high human development';
  if (score >= 6) return 'High human development';
  if (score >= 4) return 'Medium human development';
  return 'Lower human development; research local conditions carefully';
}

const metricConfigs = [
  { key: 'safety', label: 'Safety', raw: data.raw?.safety, unit: 'GPI score (lower = safer)', interpret: interpretSafety },
  { key: 'healthcare', label: 'Healthcare', raw: data.raw?.healthcare, unit: 'UHC coverage index', interpret: interpretHealthcare },
  { key: 'happiness', label: 'Happiness', raw: data.raw?.happiness, unit: '/10 WHR score', interpret: interpretHappiness },
  { key: 'pollution', label: 'Pollution', raw: data.raw?.pollution, unit: 'Numbeo pollution index', interpret: interpretPollution },
  { key: 'internet', label: 'Internet', raw: data.raw?.internet, unit: 'Mbps avg speed', interpret: interpretInternet },
  { key: 'traffic', label: 'Traffic', raw: data.raw?.traffic, unit: 'min/year in traffic', interpret: interpretTraffic },
  { key: 'unemployment', label: 'Unemployment', raw: data.raw?.unemployment, unit: '% unemployment', interpret: interpretUnemployment },
  { key: 'hdi', label: 'Human Development', raw: data.raw?.hdi, unit: 'HDI score (UNDP)', interpret: interpretHdi },
];

const similarCountries = (() => {
  const currentContinent = data.continents?.[0];

  const allCandidates = Object.entries(allCountries)
    .filter(([s, d]) => s !== slug && d.cost_index != null && data.cost_index != null)
    .map(([s, d]) => ({
      slug: s,
      diff: Math.abs(d.cost_index - data.cost_index),
      sameContinent: currentContinent &&
        d.continents?.[0] === currentContinent,
      data: d
    }));

  const sameContinentMatches = allCandidates
    .filter(c => c.sameContinent)
    .sort((a, b) => a.diff - b.diff);

  if (sameContinentMatches.length >= 3) {
    return sameContinentMatches.slice(0, 3);
  }

  const remaining = allCandidates
    .filter(c => !c.sameContinent)
    .sort((a, b) => a.diff - b.diff);

  return [
    ...sameContinentMatches,
    ...remaining
  ].slice(0, 3);
})();

// Country-specific FAQ
const faqs = [
  {
    q: `Is ${countryName} safe for Americans?`,
    a: data.safety >= 8
      ? `${countryName} ranks ${data.safety}/10 for safety on the Global Peace Index, well above the global average. Like anywhere, safety varies by neighborhood, so research specific areas before committing.`
      : data.safety >= 6
      ? `${countryName} rates ${data.safety}/10 for safety, which is reasonable, though conditions vary by region. Standard travel precautions are recommended.`
      : `${countryName} rates ${data.safety}/10 for safety. Research specific cities and neighborhoods carefully, and consider speaking with expats currently living there.`
  },
  {
    q: `Do Americans need a visa for ${countryName}?`,
    a: data.visa_days >= 90
      ? `US passport holders can typically enter ${countryName} visa-free for up to ${data.visa_days} days. Long-term residency requires a separate visa or residence permit application.`
      : data.visa_days >= 30
      ? `US passport holders can typically enter ${countryName} with a visa on arrival or short visa-free stay of up to ${data.visa_days} days. Longer stays require advance visa arrangements.`
      : `${countryName} generally requires US citizens to obtain a visa before travel. Check the nearest consulate for current requirements.`
  },
  {
    q: `How much tax do Americans pay in ${countryName}?`,
    a: data.tax_system === 'zero'
      ? `${countryName} has no personal income tax. However, US citizens are still required to file US federal taxes on worldwide income regardless of where they live. Consult a tax professional familiar with expat taxation.`
      : data.tax_system === 'territorial'
      ? `${countryName} uses a territorial tax system, meaning foreign-sourced income is generally not taxed locally. US citizens still must file US federal taxes on worldwide income. Consult a qualified tax professional.`
      : `${countryName} uses worldwide taxation, meaning local tax may apply to your global income in addition to US filing obligations. The Foreign Earned Income Exclusion (FEIE) may reduce US tax liability. Consult a tax professional specializing in expat taxes.`
  },
  {
    q: `Does ${countryName} have a digital nomad visa?`,
    a: data.nomad_visa
      ? `Yes, ${countryName} offers a digital nomad visa or remote work permit for foreigners earning income from outside the country. Requirements typically include proof of remote income and health insurance.`
      : `${countryName} does not currently have a dedicated digital nomad visa program. Remote workers typically rely on tourist visas, standard work visas, or other residency pathways.`
  },
  {
    q: `What is the cost of living in ${countryName} compared to the US?`,
    a: data.us_comparison
      ? `Living in ${countryName} is ${data.us_comparison}. A single person can expect to spend around $${data.budget_single}/month on average, excluding rent.`
      : `Cost of living data for ${countryName} is being updated. Use our calculator above for a personalized comparison based on your US city and income.`
  },
  {
    q: `Is English widely spoken in ${countryName}?`,
    a: data.english >= 999
      ? `Yes, English is the primary language in ${countryName}.`
      : data.english >= 600
      ? `${countryName} has very high English proficiency (EF EPI score of ${data.english}), making daily life and business easy to navigate without learning the local language.`
      : data.english >= 500
      ? `${countryName} has high English proficiency (EF EPI score of ${data.english}). English is widely understood, especially in cities and business settings, though learning basic local phrases is still useful.`
      : data.english >= 400
      ? `${countryName} has moderate English proficiency (EF EPI score of ${data.english}). English is commonly understood in cities and tourist areas, but learning basic local phrases is recommended.`
      : `${countryName} has lower English proficiency (EF EPI score of ${data.english}). Learning the local language will significantly improve daily life and integration.`
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a
    }
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://leavingamerica.co" },
    { "@type": "ListItem", "position": 2, "name": "Countries", "item": "https://leavingamerica.co/countries" },
    { "@type": "ListItem", "position": 3, "name": countryName, "item": `https://leavingamerica.co/countries/${slug}` }
  ]
};

const pageTitle = `Moving to ${countryName} from USA: Cost, Visa & Healthcare Guide (2026) | LeavingAmerica`;
const pageDescription = `See how far your salary goes in ${countryName}. ${data.us_comparison ? 'Living costs are ' + data.us_comparison + '.' : ''} Compare visa requirements, healthcare, and taxes for Americans. Free calculator.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<style>
* { box-sizing: border-box; }

.country-page {
  font-family: 'Manrope', sans-serif;
  background: #F8FAFC;
}

.breadcrumb {
  max-width: 1100px;
  margin: 0 auto;
  padding: 100px 24px 0;
  font-size: 13px;
  color: #94A3B8;
}
.breadcrumb a {
  color: #64748B;
  text-decoration: none;
}
.breadcrumb a:hover { color: #2563EB; }

.data-freshness {
  max-width: 1100px;
  margin: 0 auto;
  padding: 8px 24px 0;
  font-size: 12px;
  color: #94A3B8;
}

.country-hero {
  max-width: 1100px;
  margin: 0 auto;
  padding: 24px 24px 40px;
}
.country-hero h1 {
  font-size: 38px;
  font-weight: 800;
  color: #0F172A;
  line-height: 1.2;
  margin-bottom: 16px;
  max-width: 800px;
}
.country-hero-sub {
  font-size: 17px;
  color: #64748B;
  line-height: 1.7;
  max-width: 680px;
}

.verdict-bar {
  max-width: 1100px;
  margin: 0 auto 40px;
  padding: 0 24px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}
.verdict-item {
  background: white;
  border-radius: 14px;
  padding: 18px 20px;
  border-left: 3px solid #E2E8F0;
  box-shadow: 0 1px 6px rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
}
.verdict-item.favorable { border-left-color: #16A34A; }
.verdict-item.neutral { border-left-color: #D97706; }
.verdict-item.restricted { border-left-color: #DC2626; }
.verdict-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #94A3B8;
  margin-bottom: 0;
}
.verdict-value {
  flex: 1;
  display: flex;
  align-items: center;
  font-size: 18px;
  font-weight: 700;
  color: #0F172A;
  line-height: 1.2;
}
.verdict-gauge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  border-left: none;
  padding-top: 12px;
}
.verdict-gauge-item .verdict-label {
  margin-bottom: 8px;
}

.section {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px 56px;
}

.preview-card {
  background: linear-gradient(135deg, #F8FAFF 0%, #EEF2FF 100%);
  border: 1px solid #C7D2FE;
  border-radius: 20px;
  padding: 36px;
  text-align: center;
}
.preview-card-label {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #2563EB;
  margin-bottom: 12px;
}
.preview-card-text {
  font-size: 22px;
  font-weight: 700;
  color: #0F172A;
  line-height: 1.4;
  margin-bottom: 20px;
  max-width: 560px;
  margin-left: auto;
  margin-right: auto;
}
.preview-cta {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #2563EB, #0EA5E9);
  color: white;
  font-size: 15px;
  font-weight: 700;
  padding: 14px 28px;
  border-radius: 10px;
  text-decoration: none;
  transition: all 0.2s ease;
}
.preview-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(37,99,235,0.3);
}
.cta-microtrust {
  font-size: 12px;
  color: #94A3B8;
  margin-top: 12px;
  text-align: center;
}

.section-title {
  font-size: 26px;
  font-weight: 800;
  color: #0F172A;
  margin-bottom: 8px;
}
.section-sub {
  font-size: 14px;
  color: #64748B;
  margin-bottom: 24px;
}

.reasons-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
.reason-card {
  background: white;
  border-radius: 12px;
  padding: 16px 18px;
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 14px;
  color: #374151;
  line-height: 1.5;
  border-left: 3px solid #16A34A;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
