  font-size: 14px;
  color: #64748B;
  line-height: 1.7;
}

.similar-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16px;
}
.similar-card {
  background: white;
  border-radius: 14px;
  padding: 20px;
  text-decoration: none;
  box-shadow: 0 1px 6px rgba(0,0,0,0.05);
  transition: all 0.2s ease;
