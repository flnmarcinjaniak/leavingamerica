---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Country Match | Find Your Best Country Abroad | LeavingAmerica.co"
  description="Answer 10 questions and get a personalized ranking of countries that match your financial goals, lifestyle, and priorities. 82 countries analyzed.">

<style is:global>
* { box-sizing: border-box; }

.cm-page {
  background: #F8FAFC;
  font-family: 'Manrope', sans-serif;
  min-height: 100vh;
  padding: 60px 24px 80px;
}

.cm-wrap {
  max-width: 960px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 56px;
  align-items: center;
}

/* ─── Left: intro ─────────────────────────────── */
.cm-intro-eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #2563EB;
  margin-bottom: 16px;
}

.cm-intro h1 {
  font-size: clamp(28px, 4vw, 44px);
  font-weight: 800;
  color: #0F172A;
  line-height: 1.18;
  letter-spacing: -0.5px;
  margin-bottom: 18px;
}

.cm-intro h1 em {
  font-style: normal;
  color: #2563EB;
}

.cm-intro-desc {
  font-size: 16px;
  color: #475569;
  line-height: 1.7;
  margin-bottom: 28px;
  max-width: 460px;
}

.cm-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 20px;
  margin-bottom: 36px;
}

.cm-meta-item {
  font-size: 13px;
  color: #64748B;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 7px;
}

.cm-meta-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #2563EB;
  flex-shrink: 0;
}

.cm-btn {
  display: inline-block;
  background: linear-gradient(135deg, #2563EB, #0EA5E9);
  color: white;
  font-size: 16px;
  font-weight: 700;
  padding: 16px 40px;
  border-radius: 12px;
  text-decoration: none;
  font-family: 'Manrope', sans-serif;
  transition: transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 6px 24px rgba(37,99,235,0.32);
}

.cm-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 32px rgba(37,99,235,0.44);
}

.cm-note {
  display: block;
  margin-top: 12px;
  font-size: 12px;
  color: #94A3B8;
}

/* ─── Right: preview card ─────────────────────── */
.cm-card {
  background: white;
  border-radius: 20px;
  padding: 28px;
  border: 1.5px solid #BFDBFE;
  box-shadow: 0 4px 28px rgba(37,99,235,0.10);
  position: relative;
  overflow: hidden;
}

.cm-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #2563EB, #0EA5E9);
}

.cm-card-badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 4px 12px;
  border-radius: 100px;
  background: #1E40AF;
  color: #fff;
  margin-bottom: 14px;
}

.cm-card-country {
  font-size: 30px;
  font-weight: 800;
  color: #0F172A;
  margin-bottom: 6px;
  letter-spacing: -0.3px;
}

.cm-card-score-row {
  display: flex;
  align-items: baseline;
  gap: 6px;
  margin-bottom: 10px;
}

.cm-card-score {
  font-size: 32px;
  font-weight: 800;
  color: #2563EB;
  line-height: 1;
}

.cm-card-score-label {
  font-size: 13px;
  color: #64748B;
  font-weight: 500;
}

.cm-card-meter {
  height: 6px;
  background: #EFF6FF;
  border-radius: 100px;
  margin-bottom: 22px;
  overflow: hidden;
}

.cm-card-meter-fill {
  height: 100%;
  width: 93%;
  background: linear-gradient(90deg, #2563EB, #0EA5E9);
  border-radius: 100px;
}

.cm-card-reasons {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.cm-card-reason {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: #374151;
  line-height: 1.45;
}

.cm-card-check {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #DCFCE7;
  color: #16A34A;
  font-size: 9px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cm-card-caption {
  font-size: 11px;
  color: #94A3B8;
  text-align: center;
  margin-top: 16px;
}

/* ─── Responsive ─────────────────────────────── */
@media (max-width: 768px) {
  .cm-page { padding: 40px 20px 60px; }
  .cm-wrap {
    grid-template-columns: 1fr;
    gap: 36px;
  }
  .cm-intro h1 { font-size: 28px; }
}
</style>

<div class="cm-page">
  <div class="cm-wrap">

    <!-- Left: intro -->
    <div class="cm-intro">
      <p class="cm-intro-eyebrow">Country Match</p>
      <h1>Find the country that<br/><em>fits your life</em></h1>
      <p class="cm-intro-desc">
        Answer 10 questions about your finances, lifestyle, and priorities.
        We score 82 countries against your answers and explain exactly why each one fits — or doesn't.
      </p>

      <div class="cm-meta">
        <span class="cm-meta-item"><span class="cm-meta-dot"></span> 10 questions</span>
        <span class="cm-meta-item"><span class="cm-meta-dot"></span> About 2 minutes</span>
        <span class="cm-meta-item"><span class="cm-meta-dot"></span> 82 countries analyzed</span>
        <span class="cm-meta-item"><span class="cm-meta-dot"></span> No signup required</span>
      </div>

      <a href="/country-match/quiz" class="cm-btn">Start Country Match →</a>
      <span class="cm-note">Your answers are not stored or shared.</span>
    </div>

    <!-- Right: preview card -->
    <div>
      <div class="cm-card">
        <div class="cm-card-badge">Top Match · Example</div>
        <div class="cm-card-country">Portugal</div>
        <div class="cm-card-score-row">
          <span class="cm-card-score">93%</span>
          <span class="cm-card-score-label">Match Score</span>
        </div>
        <div class="cm-card-meter">
          <div class="cm-card-meter-fill"></div>
        </div>
        <div class="cm-card-reasons">
          <div class="cm-card-reason">
            <span class="cm-card-check">✓</span>
            Healthcare rated 9/10 — universal coverage
          </div>
          <div class="cm-card-reason">
            <span class="cm-card-check">✓</span>
            Very high English proficiency (617 EF EPI)
          </div>
          <div class="cm-card-reason">
            <span class="cm-card-check">✓</span>
            Digital Nomad Visa available
          </div>
          <div class="cm-card-reason">
            <span class="cm-card-check">✓</span>
            Strong purchasing power advantage vs the US
          </div>
          <div class="cm-card-reason">
            <span class="cm-card-check">✓</span>
            180 days visa-free on a US passport
          </div>
        </div>
      </div>
      <p class="cm-card-caption">Sample result — yours will reflect your specific answers</p>
    </div>

  </div>
</div>

</BaseLayout>
