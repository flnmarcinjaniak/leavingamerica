<script>
(function() {

const answers = {};
let currentQ = 0;
const TOTAL = 8;

const NAMES = {
  'portugal':'Portugal','spain':'Spain',
  'poland':'Poland','mexico':'Mexico',
  'thailand':'Thailand','germany':'Germany',
  'japan':'Japan','croatia':'Croatia',
  'czech-republic':'Czech Republic',
  'hungary':'Hungary','romania':'Romania',
  'bulgaria':'Bulgaria','vietnam':'Vietnam',
  'south-korea':'South Korea',
  'australia':'Australia','new-zealand':'New Zealand',
  'canada':'Canada','ireland':'Ireland',
  'netherlands':'Netherlands','france':'France',
  'argentina':'Argentina','ecuador':'Ecuador',
  'morocco':'Morocco','switzerland':'Switzerland',
  'norway':'Norway','denmark':'Denmark',
  'sweden':'Sweden','belgium':'Belgium',
  'austria':'Austria','finland':'Finland',
  'united-kingdom':'United Kingdom',
  'singapore':'Singapore',
  'united-arab-emirates':'UAE',
  'qatar':'Qatar','saudi-arabia':'Saudi Arabia',
  'iceland':'Iceland','india':'India',
  'philippines':'Philippines','china':'China',
  'georgia':'Georgia','serbia':'Serbia',
  'kenya':'Kenya','peru':'Peru',
  'brazil':'Brazil','chile':'Chile',
  'albania':'Albania','sri-lanka':'Sri Lanka',
  'egypt':'Egypt','indonesia':'Indonesia',
  'colombia':'Colombia','costa-rica':'Costa Rica',
  'panama':'Panama','malaysia':'Malaysia',
  'italy':'Italy','greece':'Greece'
};

const QUALITY = JSON.parse(
  document.getElementById('quality-data-quiz').textContent
);

const EXPENSIVE_COL = new Set([
  'singapore','switzerland','norway','denmark',
  'sweden','finland','iceland','netherlands',
  'ireland','australia','new-zealand',
  'united-kingdom','austria','belgium',
  'united-arab-emirates','qatar','saudi-arabia',
  'france','germany','japan','south-korea',
  'canada','israel'
]);

const AFFORDABLE_COL = new Set([
  'vietnam','thailand','indonesia','philippines',
  'india','sri-lanka',
  'georgia','albania','romania','bulgaria',
  'hungary','serbia','poland','czech-republic','croatia',
  'egypt','morocco',
  'colombia','peru','ecuador','mexico',
  'costa-rica','panama'
]);

// ── Progress steps ─────────────────────────────
function buildProgressSteps() {
  var container = document.getElementById('progressSteps');
  container.innerHTML = '';
  for (var i = 1; i <= TOTAL; i++) {
    var div = document.createElement('div');
    div.className = 'qp-step';
    div.id = 'qpstep' + i;
    container.appendChild(div);
  }
}

function updateProgressSteps(q) {
  for (var i = 1; i <= TOTAL; i++) {
    var el = document.getElementById('qpstep' + i);
    if (!el) continue;
    el.classList.remove('done', 'active');
    if (i < q) el.classList.add('done');
    else if (i === q) el.classList.add('active');
  }
}

// ── Quiz flow ──────────────────────────────────
window.selectOption = function(qNum, value) {
  answers[qNum] = value;
  var screen = document.getElementById('q' + qNum);
  screen.querySelectorAll('.option-card').forEach(function(c) {
    c.classList.remove('selected');
  });
  event.currentTarget.classList.add('selected');
  var nextBtn = document.getElementById('next' + qNum);
  if (nextBtn) nextBtn.disabled = false;
};

window.nextQuestion = function(current) {
  if (!answers[current]) return;
  showQuestion(current + 1);
};

window.prevQuestion = function(current) {
  if (current <= 1) return;
  showQuestion(current - 1);
};

function showQuestion(num) {
  document.querySelectorAll('.question-screen').forEach(function(s) {
    s.classList.remove('active');
  });
  if (num >= 1 && num <= TOTAL) {
    currentQ = num;
    document.getElementById('q' + num).classList.add('active');
    updateProgressSteps(num);
    document.getElementById('progressText').textContent =
      'Question ' + num + ' of ' + TOTAL;
    if (answers[num]) {
      var nextBtn = document.getElementById('next' + num);
      if (nextBtn) nextBtn.disabled = false;
      document.getElementById('q' + num)
        .querySelectorAll('.option-card').forEach(function(c) {
          c.classList.remove('selected');
          var fn = c.getAttribute('onclick');
          if (fn && fn.indexOf("'" + answers[num] + "'") !== -1) {
            c.classList.add('selected');
          }
        });
    }
  }
}

// ── Scoring ────────────────────────────────────
window.calculateResults = function() {
  if (!answers[8]) return;
  var scores = {};

  Object.entries(QUALITY).forEach(function([slug, q]) {
    var score = 0;
    var w = {
      safety:0.25, healthcare:0.20, happiness:0.15,
      gdpGrowth:0.05, pollution:0.10, unemployment:0.10,
      internet:0.10, traffic:0.05
    };
    var base = 0, totalW = 0;
    Object.entries(w).forEach(function([k, weight]) {
      if (q[k] != null) { base += q[k] * weight; totalW += weight; }
    });
    score = totalW > 0 ? (base / totalW) * 5 + 15 : 45;

    if (answers[1] === 'cost') {
      if (EXPENSIVE_COL.has(slug)) score -= 32;
      if (AFFORDABLE_COL.has(slug)) score += 22;
      if (q.unemployment >= 8) score += 10;
      if (q.gdpGrowth >= 7) score += 5;
    }
    if (answers[1] === 'healthcare') { score += (q.healthcare || 5) * 3; }
    if (answers[1] === 'retirement') {
      if (q.healthcare >= 8) score += 16;
      if (q.happiness >= 7) score += 12;
    }
    if (answers[1] === 'balance') {
      if (q.happiness >= 8) score += 16;
      if (q.traffic >= 7) score += 12;
      if (q.pollution >= 7) score += 8;
    }
    if (answers[1] === 'safety') { score += (q.safety || 5) * 4; }
    if (answers[1] === 'freedom') {
      if (q.nomad_visa) score += 18;
      if (q.happiness >= 7) score += 12;
      if (q.pollution >= 7) score += 8;
    }

    if (answers[2] === 'remote' || answers[2] === 'freelance') {
      if (q.nomad_visa) score += 22;
      if (q.internet >= 8) score += 12;
    }
    if (answers[2] === 'business') {
      if (q.tax_system === 'zero') score += 28;
      else if (q.tax_system === 'territorial') score += 18;
      if (q.internet >= 8) score += 8;
    }
    if (answers[2] === 'family') {
      score += (q.safety || 5) * 3.5;
      score += (q.healthcare || 5) * 2.5;
      if (q.english >= 500) score += 14;
    }
    if (answers[2] === 'preretire' || answers[2] === 'retired') {
      score += (q.healthcare || 5) * 3.5;
      score += (q.safety || 5) * 2.5;
      if (q.happiness >= 7) score += 14;
      if (EXPENSIVE_COL.has(slug)) score -= 28;
      if (AFFORDABLE_COL.has(slug)) score += 20;
    }

    if (answers[3] === 'savemore') {
      if (EXPENSIVE_COL.has(slug)) score -= 28;
      if (AFFORDABLE_COL.has(slug)) score += 20;
      if (q.unemployment >= 8) score += 10;
      if (q.gdpGrowth >= 7) score += 6;
    }
    if (answers[3] === 'retire') {
      if (q.healthcare >= 8) score += 18;
      if (q.happiness >= 7) score += 14;
    }
    if (answers[3] === 'taxes') {
      if (q.tax_system === 'zero') score += 32;
      else if (q.tax_system === 'territorial') score += 22;
    }
    if (answers[3] === 'lifestyle') {
      if (q.happiness >= 8) score += 16;
      if (q.pollution >= 7) score += 12;
    }
    if (answers[3] === 'quality') {
      if (q.happiness >= 8) score += 18;
      if (q.pollution >= 7) score += 12;
      if (q.traffic >= 7) score += 10;
    }

    if (answers[4] === 'cost' || answers[4] === 'coverage' || answers[4] === 'access') {
      score += (q.healthcare || 5) * 4;
    }

    if (answers[5] === 'english_only') {
      if (q.english >= 600) score += 28;
      else if (q.english >= 500) score += 14;
      else if (q.english < 450) score -= 28;
    }
    if (answers[5] === 'mostly') {
      if (q.english >= 500) score += 14;
      else if (q.english < 400) score -= 14;
    }

    if (answers[6] === 'healthcare') score += (q.healthcare || 5) * 4;
    if (answers[6] === 'safety')     score += (q.safety || 5) * 4;
    if (answers[6] === 'nature')     score += (q.pollution || 5) * 4;
    if (answers[6] === 'internet')   score += (q.internet || 5) * 4;
    if (answers[6] === 'economy') {
      score += (q.gdpGrowth || 5) * 3;
      score += (q.unemployment || 5) * 3;
    }
    if (answers[6] === 'traffic') score += (q.traffic || 5) * 4;

    if (answers[7] === 'critical') {
      if (q.nomad_visa) score += 24;
      if (q.visa_days >= 180) score += 14;
      else if (q.visa_days >= 90) score += 8;
    }
    if (answers[7] === 'important') {
      if (q.nomad_visa) score += 14;
    }

    scores[slug] = score;
  });

  var sorted = Object.entries(scores).sort(function(a, b) { return b[1] - a[1]; });
  var maxScore = sorted[0][1];
  var top3 = sorted.slice(0, 3).map(function([slug, s]) {
    return {
      slug: slug,
      score: Math.min(98, Math.round((s / maxScore) * 95) + Math.floor(Math.random() * 4)),
      data: QUALITY[slug]
    };
  });

  showResults(top3);
};

// ── Reasons ────────────────────────────────────
function generateReasons(slug, data, userAnswers) {
  var reasons = [];
  if (data.healthcare >= 9) {
    reasons.push('Healthcare rated ' + data.healthcare + '/10 — high-quality care at a fraction of US costs');
  } else if (data.healthcare >= 7 &&
    (userAnswers[1] === 'healthcare' || userAnswers[4] !== 'nothing' || userAnswers[6] === 'healthcare')) {
    reasons.push('Solid healthcare infrastructure rated ' + data.healthcare + '/10');
  }
  if (data.safety >= 8) {
    reasons.push('Ranked ' + data.safety + '/10 for personal safety — well above global average');
  } else if (data.safety >= 7 && (userAnswers[1] === 'safety' || userAnswers[6] === 'safety')) {
    reasons.push('Safety rated ' + data.safety + '/10');
  }
  if (data.english >= 999) {
    reasons.push('Native English-speaking country — no language barrier');
  } else if (data.english >= 600) {
    reasons.push('Very high English proficiency (' + data.english + ' EF EPI) — easy to navigate daily life');
  } else if (data.english >= 500 && userAnswers[5] === 'mostly') {
    reasons.push('High English proficiency in major cities and business settings');
  }
  if (data.tax_system === 'zero') {
    reasons.push('No personal income tax — keep significantly more of what you earn');
  } else if (data.tax_system === 'territorial' && userAnswers[3] === 'taxes') {
    reasons.push('Territorial tax system — foreign income generally not taxed locally');
  }
  if (data.nomad_visa &&
    (userAnswers[2] === 'remote' || userAnswers[2] === 'freelance' || userAnswers[7] === 'critical')) {
    reasons.push('Digital Nomad Visa available — a clear legal path for remote workers');
  }
  if (data.visa_days >= 180) {
    reasons.push(data.visa_days + ' days visa-free on a US passport');
  } else if (data.visa_days >= 90) {
    reasons.push('90-day visa-free entry for US passport holders');
  }
  if (data.happiness >= 8) {
    reasons.push('Consistently ranks among the happiest countries in the world');
  }
  if (data.internet >= 9 && (userAnswers[2] === 'remote' || userAnswers[6] === 'internet')) {
    reasons.push('Fast internet infrastructure — ideal for remote work');
  }
  if (data.pollution >= 8 && userAnswers[6] === 'nature') {
    reasons.push('Clean environment rated ' + data.pollution + '/10');
  }
  return reasons.slice(0, 5);
}

// ── Profile summary ────────────────────────────
function getProfileSummary(userAnswers) {
  var items = [];
  var q1map = {
    cost: 'You prioritize lowering your cost of living',
    healthcare: 'Healthcare costs are your main frustration',
    retirement: 'You want to retire earlier than the US allows',
    balance: 'Work-life balance is a top priority for you',
    safety: 'Personal safety is a significant concern',
    freedom: 'You want more freedom and personal autonomy'
  };
  var q2map = {
    remote: 'You work remotely for a US company',
    freelance: 'You freelance or contract independently',
    business: 'You run your own business',
    family: 'You are relocating as a family with children',
    preretire: 'You are planning early retirement',
    retired: 'You are already retired'
  };
  var q7map = {
    critical: 'A legal path to long-term residency is essential',
    important: 'Long-term residency options matter to you',
    explore: 'You are still in the research phase'
  };
  if (q1map[userAnswers[1]]) items.push(q1map[userAnswers[1]]);
  if (q2map[userAnswers[2]]) items.push(q2map[userAnswers[2]]);
  if (q7map[userAnswers[7]]) items.push(q7map[userAnswers[7]]);
  return items;
}

// ── Affiliates ─────────────────────────────────
var AFFILIATE_CATALOG = {
  wise: {
    name: 'Wise', icon: 'W',
    desc: 'Multi-currency account — send money abroad at the real exchange rate with no hidden fees',
    cta: 'Open free account', url: '#', enabled: true,
    whyFn: function() { return 'You\'ll need to move money internationally once you relocate'; }
  },
  wise_business: {
    name: 'Wise Business', icon: 'W',
    desc: 'Multi-currency business account built for companies operating across borders',
    cta: 'Open business account', url: '#', enabled: true,
    whyFn: function() { return 'Managing international revenue and expenses as a business owner abroad'; }
  },
  safetywing: {
    name: 'SafetyWing', icon: 'S',
    desc: 'Global health coverage from $45/month — designed for people living outside their home country',
    cta: 'Get a quote', url: '#', enabled: true,
    whyFn: function(ans) {
      if (ans[2] === 'retired' || ans[2] === 'preretire')
        return 'US health insurance typically won\'t cover you abroad — this fills that gap';
      return 'Health coverage abroad is essential and often overlooked until you need it';
    }
  },
  nordvpn: {
    name: 'NordVPN', icon: 'N',
    desc: 'Keep access to US streaming, banking apps, and secure your connection from anywhere',
    cta: 'Try free for 30 days', url: '#', enabled: true,
    whyFn: function() { return 'Maintain access to US banking, streaming, and services from abroad'; }
  },
  ivisa: {
    name: 'iVisa', icon: 'V',
    desc: 'Simplify your visa applications with guided support and fast processing',
    cta: 'Check visa requirements', url: '#', enabled: true,
    whyFn: function() { return 'You\'re planning to move soon — starting the visa process early matters'; }
  }
};

function getAffiliates(userAnswers) {
  var stage    = userAnswers[2];
  var timeline = userAnswers[8];
  var showIvisa = AFFILIATE_CATALOG.ivisa.enabled &&
    (timeline === 'oneyear' || timeline === 'soon');
  var keys = [];
  if (stage === 'business') {
    keys = ['wise_business', 'nordvpn'];
    if (showIvisa) keys.splice(1, 0, 'ivisa');
  } else if (stage === 'remote' || stage === 'freelance') {
    keys = ['wise', 'safetywing', 'nordvpn'];
    if (showIvisa) keys.splice(2, 0, 'ivisa');
  } else {
    keys = ['wise', 'safetywing'];
    if (showIvisa) keys.push('ivisa');
  }
  return keys
    .filter(function(k) { return AFFILIATE_CATALOG[k] && AFFILIATE_CATALOG[k].enabled; })
    .slice(0, 4)
    .map(function(k) { return AFFILIATE_CATALOG[k]; });
}

// ── Show Results ───────────────────────────────
function showResults(top3) {
  document.querySelectorAll('.question-screen').forEach(function(s) {
    s.classList.remove('active');
  });
  document.getElementById('quizProgress').style.display = 'none';

  var topMatch     = top3[0];
  var countryName  = NAMES[topMatch.slug] || topMatch.slug;
  var topReasons   = generateReasons(topMatch.slug, topMatch.data, answers);
  var profileItems = getProfileSummary(answers);

  var profileHTML = '';
  if (profileItems.length > 0) {
    profileHTML =
      '<div class="match-profile-summary">' +
      '<div class="match-profile-title">Based on your answers</div>' +
      '<div class="match-profile-items">' +
      profileItems.map(function(item) {
        return '<div class="match-profile-item">' +
          '<div class="match-profile-dot">✓</div>' +
          '<span>' + item + '</span>' +
          '</div>';
      }).join('') +
      '</div></div>';
  }

  document.getElementById('topMatchContainer').innerHTML =
    '<div class="top-match">' +
    '<div class="match-badge">Top Match</div>' +
    '<div class="match-country-name">' + countryName + '</div>' +
    '<div class="match-score-meter">' +
    '<div class="match-score-top">' +
    '<span class="match-percent">' + topMatch.score + '%</span>' +
    '<span class="match-percent-label">Match Score</span>' +
    '</div>' +
    '<div class="match-meter-track">' +
    '<div class="match-meter-fill" id="matchMeterFill"></div>' +
    '</div></div>' +
    profileHTML +
    '<div class="match-why-title">Why ' + countryName + ' Fits You</div>' +
    '<div class="match-reasons">' +
    topReasons.map(function(r) {
      return '<div class="match-reason">' +
        '<div class="match-reason-check">&#10003;</div>' +
        '<span>' + r + '</span></div>';
    }).join('') +
    '</div>' +
    '<a href="/#calculator" class="btn-calculate" ' +
    'onclick="prefillCalculator(\'' + topMatch.slug + '\')">' +
    'Compare My Salary in ' + countryName + ' →</a>' +
    '</div>';

  setTimeout(function() {
    var fill = document.getElementById('matchMeterFill');
    if (fill) fill.style.width = topMatch.score + '%';
  }, 60);

  function nextRow(href, label, oc) {
    return '<a href="' + href + '" class="next-step-link"' +
      (oc ? ' onclick="' + oc + '"' : '') + '>' +
      '<span class="next-step-left"><span class="next-step-icon">✓</span>' + label + '</span>' +
      '<span class="next-step-arrow">→</span></a>';
  }

  document.getElementById('nextStepsContainer').innerHTML =
    '<div class="next-steps">' +
    '<div class="next-steps-title">Recommended Next Steps</div>' +
    '<div class="next-steps-list">' +
    nextRow('/countries', 'View ' + countryName + ' Country Profile') +
    nextRow('/#calculator', 'Compare Your Salary in ' + countryName,
      'prefillCalculator(\'' + topMatch.slug + '\')') +
    nextRow('/tools/visa', 'Explore Visa Options for ' + countryName) +
    '</div></div>';

  document.getElementById('altMatchesContainer').innerHTML =
    top3.slice(1).map(function(m) {
      var name = NAMES[m.slug] || m.slug;
      return '<div class="alt-match" onclick="prefillCalculator(\'' + m.slug + '\')">' +
        '<div class="alt-match-name">' + name + '</div>' +
        '<div><span class="alt-match-score">' + m.score + '%</span>' +
        '<span class="alt-match-score-label"> Match</span></div></div>';
    }).join('');

  var aff = getAffiliates(answers);
  document.getElementById('affiliateBlock').innerHTML =
    '<h3>Recommended Resources for Your Move</h3>' +
    '<p>Selected based on your profile — only the tools most relevant to your situation.</p>' +
    '<div class="affiliate-cards">' +
    aff.map(function(a) {
      var why = a.whyFn ? a.whyFn(answers) : '';
      return '<a href="' + a.url + '" class="affiliate-card" target="_blank" rel="noopener sponsored">' +
        '<div class="affiliate-card-icon">' + a.icon + '</div>' +
        '<div class="affiliate-card-body">' +
        '<div class="affiliate-card-name">' + a.name + '</div>' +
        (why ? '<div class="affiliate-card-why">Recommended because: ' + why + '</div>' : '') +
        '<div class="affiliate-card-desc">' + a.desc + '</div>' +
        '</div>' +
        '<div class="affiliate-card-cta">' + a.cta + ' →</div>' +
        '</a>';
    }).join('') +
    '</div>';

  document.getElementById('resultsScreen').classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

window.prefillCalculator = function(slug) {
  sessionStorage.setItem('quiz_country', slug);
  window.location.href = '/#calculator';
};

window.restartQuiz = function() {
  Object.keys(answers).forEach(function(k) { delete answers[k]; });
  document.querySelectorAll('.option-card').forEach(function(c) {
    c.classList.remove('selected');
  });
  document.querySelectorAll('.btn-next').forEach(function(b) { b.disabled = true; });
  document.getElementById('resultsScreen').classList.remove('active');
  document.getElementById('quizProgress').style.display = 'block';
  showQuestion(1);
  window.scrollTo({ top: 0, behavior: 'smooth' });
};

// Auto-start Q1 on page load
buildProgressSteps();
showQuestion(1);

})();
</script>

</BaseLayout>
