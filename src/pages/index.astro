  /* ── Trust sidebar ── */

  .trust-sidebar {
    padding: 0;
  }

  .calc-trust { gap: 16px; }
  .calc-trust-header { margin-bottom: 8px; }
  .calc-checklist { margin-top: 8px; }

  .trust-sidebar-badge {
    display: inline-flex;
    align-items: center;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: #2563EB;
    text-transform: uppercase;
    background: #EFF6FF;
    border: 1px solid #BFDBFE;
    border-radius: 100px;
    padding: 4px 12px;
    margin-top: 4px;
    margin-bottom: 8px;
  }

  .trust-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 0;
  }

  .trust-stat {
    background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFF 100%);
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    padding: 20px 14px 16px;
    text-align: center;
    position: relative;
    overflow: hidden;
    cursor: default;
    transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1),
                box-shadow 0.25s ease,
                border-color 0.25s ease;
  }

  .trust-stat::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(37,99,235,0.04) 0%, rgba(34,211,238,0.04) 100%);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .trust-stat:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(37,99,235,0.12);
    border-color: #BFDBFE;
  }

  .trust-stat:hover::after { opacity: 1; }

  .trust-stat-number {
    display: block;
    font-size: 34px;
    font-weight: 800;
    background: linear-gradient(135deg, #1D4ED8, #2563EB 50%, #0EA5E9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -1.5px;
    line-height: 1;
    margin-bottom: 5px;
    transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1);
  }

  .trust-stat:hover .trust-stat-number { transform: scale(1.04); }

  .trust-stat:nth-child(1) .trust-stat-number,
  .trust-stat:nth-child(2) .trust-stat-number { font-size: 38px; }

  .trust-stat-desc {
    display: block;
    font-size: 10.5px;
    color: #64748B;
    font-weight: 600;
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .trust-divider-animated {
    height: 1px;
    background: #F1F5F9;
    margin: 20px 0;
    overflow: hidden;
  }

  .trust-divider-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #2563EB, #22D3EE, #10B981);
    transition: width 1.2s cubic-bezier(0.25,0.46,0.45,0.94);
