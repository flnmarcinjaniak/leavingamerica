  .affiliate-icon { font-size: 32px; margin-bottom: 12px; }
  .affiliate-title { font-size: 16px; font-weight: 700; color: #0F172A; margin-bottom: 8px; }
  .affiliate-desc { font-size: 14px; color: #64748B; margin-bottom: 20px; line-height: 1.5; }

  .affiliate-btn {
    display: inline-flex;
    padding: 10px 24px;
    background: #2563EB;
    color: white;
    border-radius: 100px;
    font-weight: 600;
