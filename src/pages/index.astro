      radial-gradient(ellipse 65% 55% at 12% 20%, rgba(29,78,216,0.18) 0%, transparent 55%),
      radial-gradient(ellipse 55% 50% at 88% 80%, rgba(4,120,87,0.14) 0%, transparent 55%),
      radial-gradient(ellipse 75% 60% at 50% 50%, rgba(109,40,217,0.07) 0%, transparent 65%),
      linear-gradient(170deg, #0E1D35 0%, #090D1C 55%, #070A14 100%);
    padding: 96px 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
