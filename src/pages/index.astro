  .mobility-badge.favorable  { background: #DCFCE7; color: #15803D; }
  .mobility-badge.neutral    { background: #FEF3C7; color: #92400E; }
  .mobility-badge.restricted { background: #FEE2E2; color: #991B1B; }
  .mobility-tax-note {
    font-size: 10px;
    color: #94A3B8;
    line-height: 1.4;
    font-style: italic;
