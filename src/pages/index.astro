            visaBadge = 'Restricted';
            visaStatus = 'restricted';
          }
          setMobilityItem('mobilityVisa', 'mobilityVisaValue',
            'mobilityVisaBadge', visaText, visaBadge, visaStatus);
        } else {
          setMobilityItem('mobilityVisa', 'mobilityVisaValue',
            'mobilityVisaBadge', 'Check requirements',
            'Verify', 'neutral');
        }

        // ENGLISH
        if (englishScore !== null && englishScore !== undefined) {
          let englishText, englishBadge, englishStatus;
          if (englishScore >= 999) {
            englishText = 'Native English speaking';
            englishBadge = 'Favorable';
            englishStatus = 'favorable';
          } else if (englishScore >= 600) {
            englishText = 'Very High · ' + englishScore + ' EF EPI';
            englishBadge = 'Favorable';
            englishStatus = 'favorable';
          } else if (englishScore >= 500) {
            englishText = 'High · ' + englishScore + ' EF EPI';
            englishBadge = 'Favorable';
            englishStatus = 'favorable';
          } else if (englishScore >= 400) {
            englishText = 'Moderate · ' + englishScore + ' EF EPI';
            englishBadge = 'Neutral';
            englishStatus = 'neutral';
          } else {
            englishText = 'Low · ' + englishScore + ' EF EPI';
            englishBadge = 'Restricted';
            englishStatus = 'restricted';
          }
          setMobilityItem('mobilityEnglish', 'mobilityEnglishValue',
            'mobilityEnglishBadge', englishText,
            englishBadge, englishStatus);
        } else {
          setMobilityItem('mobilityEnglish', 'mobilityEnglishValue',
            'mobilityEnglishBadge', 'Data not available',
            'Unknown', 'neutral');
        }

        // TAX SYSTEM
        if (taxSystem) {
          let taxText, taxBadge, taxStatus;
          if (taxSystem === 'zero') {
            taxText = 'No income tax';
            taxBadge = 'Favorable';
            taxStatus = 'favorable';
          } else if (taxSystem === 'territorial') {
            taxText = 'Territorial · Foreign income exempt';
            taxBadge = 'Favorable';
            taxStatus = 'favorable';
          } else if (taxSystem === 'mixed') {
            taxText = 'Mixed · Special expat regimes';
            taxBadge = 'Neutral';
            taxStatus = 'neutral';
          } else {
            taxText = 'Worldwide · Local taxes apply';
            taxBadge = 'Neutral';
            taxStatus = 'neutral';
          }
          setMobilityItem('mobilityTax', 'mobilityTaxValue',
            'mobilityTaxBadge', taxText, taxBadge, taxStatus);
        } else {
          setMobilityItem('mobilityTax', 'mobilityTaxValue',
            'mobilityTaxBadge', 'Data not available',
            'Unknown', 'neutral');
        }

        // NOMAD VISA
        const nomadText = nomadVisa
          ? 'Available for remote workers'
          : 'No dedicated program';
        const nomadBadge = nomadVisa ? 'Yes' : 'No';
        const nomadStatus = nomadVisa ? 'favorable' : 'neutral';
        setMobilityItem('mobilityNomad', 'mobilityNomadValue',
          'mobilityNomadBadge', nomadText,
          nomadBadge, nomadStatus);

        // Subtitle
        const subtitleEl = document.getElementById('mobilitySubtitle');
        if (subtitleEl) {
          subtitleEl.textContent =
            'Entry & residency options for US citizens in ' +
            countryName;
        }
      })();

      // New share buttons
      const pageUrl = window.location.href;
      const xBtn = document.getElementById('shareX');
      const fbBtn = document.getElementById('shareFB');
      const redditBtn = document.getElementById('shareReddit');
      const copyBtn2 = document.getElementById('copyBtn');

      if (xBtn) xBtn.onclick = () => window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(shareText));
      if (fbBtn) fbBtn.onclick = () => window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(pageUrl) + '&quote=' + encodeURIComponent(shareText));
      if (redditBtn) redditBtn.onclick = () => window.open('https://www.reddit.com/submit?url=' + encodeURIComponent(pageUrl) + '&title=' + encodeURIComponent(shareText));
      if (copyBtn2) {
        copyBtn2.onclick = () => {
          navigator.clipboard.writeText(shareText).then(() => {
            const orig = copyBtn2.textContent;
            copyBtn2.textContent = 'Copied!';
            setTimeout(() => { copyBtn2.textContent = orig; }, 2000);
          });
        };
      }

      // ── END NEW JS BLOCK ──────────────────────────────────────────────────

      loadingState.style.display  = 'none';
      resultsData.style.display   = 'block';
      document.getElementById('affiliate-block').style.display = 'block';

      const cards = document.querySelectorAll('.animate-card');
      cards.forEach((card, i) => {
        card.style.opacity   = '0';
        card.style.transform = 'translateY(24px)';
        setTimeout(() => {
          card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
          card.style.opacity    = '1';
          card.style.transform  = 'translateY(0)';
        }, i * 120);
      });

    } catch (err) {
      console.error(err);
      loadingState.style.display = 'none';
      errorState.style.display   = 'block';
    } finally {
      calcBtn.disabled = false;
    }
  });

  (async function prefetch() {
    try {
      const testPPP = getCached('ppp_PL');
      const testFX  = getCached('fx_usd_EUR');

      const fetchList = [];

      const COUNTRY_CURRENCIES_PF = {
        "PT":"EUR","ES":"EUR","MX":"MXN","DE":"EUR","IT":"EUR","GR":"EUR","CR":"CRC","PA":"USD",
        "TH":"THB","MY":"MYR","ID":"IDR","CO":"COP","HR":"EUR","CZ":"CZK","PL":"PLN","HU":"HUF",
        "RO":"RON","BG":"BGN","VN":"VND","JP":"JPY","KR":"KRW","AU":"AUD","NZ":"NZD","CA":"CAD",
        "IE":"EUR","NL":"EUR","FR":"EUR","AR":"ARS","EC":"USD","MA":"MAD","AL":"ALL","AT":"EUR",
        "BE":"EUR","BR":"BRL","CL":"CLP","CN":"CNY","DK":"DKK","EG":"EGP","FI":"EUR","GE":"GEL",
        "IS":"ISK","IN":"INR","KE":"KES","NO":"NOK","PE":"PEN","PH":"PHP","QA":"QAR","SA":"SAR",
        "RS":"RSD","SG":"SGD","LK":"LKR","SE":"SEK","CH":"CHF","AE":"AED","GB":"GBP"
      };

      if (!testPPP) {
        const allISO2 = Object.keys(COUNTRY_CURRENCIES_PF).join(';');
        fetchList.push(
          fetch(`https://api.worldbank.org/v2/country/${allISO2}/indicator/PA.NUS.PRVT.PP?format=json&mrv=1&per_page=60`)
            .then(r => r.json())
            .then(data => {
              if (data[1]) {
                data[1].forEach(item => {
                  if (item.value) {
                    setCache('ppp_' + item.country.id, item.value, 24 * 60 * 60 * 1000);
                  }
                });
              }
            })
        );
      }

      if (!testFX) {
        fetchList.push(
          fetch('https://open.er-api.com/v6/latest/USD')
            .then(r => r.json())
            .then(data => {
              Object.entries(data.rates).forEach(([cur, rate]) => {
                setCache('fx_usd_' + cur, rate, 24 * 60 * 60 * 1000);
              });
            })
        );
      }

      if (fetchList.length > 0) {
        await Promise.all(fetchList);
      }
    } catch(e) {
      // silent fail
    }
  })();

  // Reveal left/right scroll animation
  (function() {
    const revealEls = document.querySelectorAll('.reveal-left, .reveal-right');
    if (!revealEls.length) return;

    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.classList.add('visible');
            }, i * 150);
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    revealEls.forEach(el => revealObserver.observe(el));
  })();

  // Count-up for trust numbers
  (function() {
    function countUp(el, target, suffix, duration) {
      const startTime = performance.now();
      function update(currentTime) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * target);
        el.textContent = current.toLocaleString() + suffix;
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }

    const trustObserver2 = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const stats = entry.target.querySelectorAll('[data-count]');
          stats.forEach((stat, i) => {
            setTimeout(() => {
              const target = parseInt(stat.dataset.count);
              const suffix = stat.dataset.suffix || '';
              countUp(stat, target, suffix, 1500);
            }, i * 150);
          });
          trustObserver2.unobserve(entry.target);
        });
      },
      { threshold: 0.3 }
    );

    const trustSection = document.querySelector(
      '.calc-trust-stats, .trust-stats, .calc-stats'
    );
    if (trustSection) trustObserver2.observe(trustSection);
  })();

  // Progress bar animation on scroll
  (function() {
    const bars = document.querySelectorAll(
      '.country-card .progress-bar, ' +
      '.country-card .mini-bar-fill'
    );
    if (!bars.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const bar = entry.target as HTMLElement;
            const width = bar.dataset.width ||
                          bar.style.width;
            bar.style.width = '0%';
            setTimeout(() => {
              bar.style.transition =
                'width 0.8s cubic-bezier(0.25,0.46,0.45,0.94)';
              bar.style.width = width;
            }, 100);
            observer.unobserve(bar);
          }
        });
      },
      { threshold: 0.2 }
    );

    bars.forEach(bar => {
      const b = bar as HTMLElement;
      const currentWidth = b.style.width ||
        getComputedStyle(b).width;
      b.dataset.width = currentWidth;
      observer.observe(b);
    });
  })();

  // Country card click → pre-select in calculator
  document.querySelectorAll('.country-card').forEach(card => {
    card.addEventListener('click', () => {
      const iso2 = card.getAttribute('data-iso2');
      (document.getElementById('countrySelect') as HTMLSelectElement).value = iso2;
      document.getElementById('calculator').scrollIntoView({ behavior: 'smooth' });
    });
  });

  // FAQ accordion
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const isOpen = answer.style.maxHeight;
      document.querySelectorAll('.faq-answer').forEach((a: any) => a.style.maxHeight = '');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!isOpen) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        btn.closest('.faq-item')!.classList.add('open');
      }
    });
  });

  // Scroll reveal
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  // ══ MOTION ENHANCEMENTS ══

  // 1. Scroll progress bar
  window.addEventListener('scroll', () => {
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
    const bar = document.getElementById('scroll-progress');
    if (bar) bar.style.width = progress + '%';
  }, { passive: true });

  // 2. Nav glassmorphism on scroll
  window.addEventListener('scroll', () => {
    const nav = (document.querySelector('.nav') || document.querySelector('nav')) as HTMLElement | null;
    if (!nav) return;
    if (window.scrollY > 80) {
      nav.style.background = 'rgba(255,255,255,0.92)';
      nav.style.backdropFilter = 'blur(20px)';
      nav.style.borderBottom = '1px solid rgba(37,99,235,0.15)';
      nav.style.boxShadow = '0 4px 24px rgba(0,0,0,0.08)';
    } else {
      nav.style.background = '';
      nav.style.backdropFilter = '';
      nav.style.borderBottom = '';
      nav.style.boxShadow = '';
    }
  }, { passive: true });

  // 3. Add reveal to additional elements and observe via existing revealObserver
  document.querySelectorAll('.result-card, .step-card, .country-card, .faq-item, .source-badge, .affiliate-card, .footer-col').forEach((el, i) => {
    el.classList.add('reveal');
    el.classList.add('reveal-delay-' + Math.min((i % 5) + 1, 5));
    revealObserver.observe(el);
  });
  document.querySelectorAll('h2, h3').forEach(el => {
    if (!el.closest('#hero') && !el.classList.contains('reveal')) {
      el.classList.add('reveal');
      revealObserver.observe(el);
    }
  });

  // 4. Hero canvas particle network
  (function() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;
    const mouse = { x: -9999, y: -9999 };
    const particles: any[] = [];

    function resizeCanvas() {
      canvas.width  = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas, { passive: true });

    canvas.parentElement!.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });

    const colors = ['#2563EB', '#22D3EE', '#60A5FA'];
    for (let i = 0; i < 60; i++) {
      particles.push({
        x: Math.random() * (canvas.width * 0.5),
        y: Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        size: Math.random() * 2 + 1,
        color: colors[Math.floor(Math.random() * colors.length)],
        opacity: Math.random() * 0.4 + 0.2,
      });
    }

    function drawCanvas() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach(p => {
        const dx = mouse.x - p.x;
        const dy = mouse.y - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 150) { p.vx += dx * 0.00005; p.vy += dy * 0.00005; }
        p.x += p.vx; p.y += p.vy;
        p.vx *= 0.99; p.vy *= 0.99;
        if (p.x < 0 || p.x > canvas.width * 0.5)  p.vx *= -1;
        if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.globalAlpha = p.opacity;
        ctx.fill();
      });
      particles.forEach((p1, i) => {
        particles.slice(i + 1).forEach(p2 => {
          const dx = p1.x - p2.x, dy = p1.y - p2.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 120) {
            ctx.beginPath();
            ctx.moveTo(p1.x, p1.y);
            ctx.lineTo(p2.x, p2.y);
            ctx.strokeStyle = '#2563EB';
            ctx.globalAlpha = (1 - dist / 120) * 0.15;
            ctx.lineWidth = 1;
            ctx.stroke();
          }
        });
      });
      ctx.globalAlpha = 1;
      requestAnimationFrame(drawCanvas);
    }
    drawCanvas();
  })();

  // 6. Card 3D tilt + glow
  function applyTilt(selector: string) {
    document.querySelectorAll<HTMLElement>(selector).forEach(card => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const rotateX = ((e.clientY - rect.top)  / rect.height - 0.5) * -16;
        const rotateY = ((e.clientX - rect.left) / rect.width  - 0.5) *  16;
        card.style.transform   = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-4px)`;
        card.style.boxShadow   = '0 20px 60px rgba(37,99,235,0.2), 0 0 0 1px rgba(37,99,235,0.1)';
        card.style.transition  = 'none';
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform  = '';
        card.style.boxShadow  = '';
        card.style.transition = 'transform 0.5s ease, box-shadow 0.5s ease';
      });
    });
  }
  applyTilt('.result-card');
  applyTilt('.country-card');
  applyTilt('.step-card');
  applyTilt('.affiliate-card');
  applyTilt('.source-badge');

  // 7. Ripple effect on CTA buttons
  document.querySelectorAll<HTMLElement>('#calcBtn').forEach(btn => {
    btn.addEventListener('click', function(this: HTMLElement, e: MouseEvent) {
      const ripple = document.createElement('span');
      const rect = this.getBoundingClientRect();
      const size = Math.max(rect.width, rect.height);
      ripple.style.cssText = [
        'position:absolute',
        `width:${size}px`, `height:${size}px`,
        `left:${e.clientX - rect.left - size / 2}px`,
        `top:${e.clientY - rect.top  - size / 2}px`,
        'background:rgba(255,255,255,0.3)',
        'border-radius:50%',
        'transform:scale(0)',
        'animation:rippleAnim 0.6s ease-out',
        'pointer-events:none',
      ].join(';');
      this.appendChild(ripple);
      setTimeout(() => ripple.remove(), 600);
    });
  });

  // 8. Steps connector animated line
  const stepsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const line = document.getElementById('stepsLine');
        if (line) {
          line.style.width = '100%';
          setTimeout(() => {
            document.querySelectorAll('.steps-arrow-between').forEach(arrow => {
              arrow.classList.add('visible');
            });
          }, 1000);
        }
        stepsObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });
  const stepsSection = document.querySelector('.steps-grid');
  if (stepsSection) stepsObserver.observe(stepsSection);

  // 10. Smooth scroll for anchor links
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(this: HTMLAnchorElement, e: Event) {
      const href = this.getAttribute('href');
      if (!href || href === '#') return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        const top = target.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });

  // 14. Stat counter (observes .stat-number if they exist)
  function animateStatCounter(el: HTMLElement, target: number, suffix: string) {
    let t0 = 0;
    const step = (ts: number) => {
      if (!t0) t0 = ts;
      const p = Math.min((ts - t0) / 2000, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(eased * target) + suffix;
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }
  const statCounterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const text = el.textContent?.trim() || '';
      if (text.includes('180')) animateStatCounter(el, 180, 'K');
      else if (text.includes('52')) animateStatCounter(el, 52, 'K');
      else if (text.includes('55')) animateStatCounter(el, 55, '');
      statCounterObserver.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll<HTMLElement>('.stat-number').forEach(el => statCounterObserver.observe(el));

  // Trust sidebar animations
  (function() {
    function animateCounter(el: HTMLElement, target: number, prefix: string, suffix: string, duration: number) {
      let start = 0;
      const step = (timestamp: number) => {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(eased * target);
        el.textContent = (prefix || '') + value + (suffix || '');
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    }

    const trustObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;

        entry.target.querySelectorAll<HTMLElement>('.trust-stat')
          .forEach((stat, i) => {
            const el = stat.querySelector<HTMLElement>('.trust-stat-number');
            if (!el) return;
            const target = parseInt((stat as HTMLElement).dataset.count || '0');
            const prefix = (stat as HTMLElement).dataset.prefix || '';
            const suffix = (stat as HTMLElement).dataset.suffix || '';
            setTimeout(() => {
              animateCounter(el, target, prefix, suffix, 1200);
            }, i * 150);
          });

        const divider = entry.target.querySelector<HTMLElement>('.trust-divider-fill');
        if (divider) {
          setTimeout(() => {
            divider.classList.add('animated');
          }, 600);
        }

        entry.target.querySelectorAll<HTMLElement>('.trust-feature')
          .forEach((feature, i) => {
            setTimeout(() => {
              feature.classList.add('visible');
            }, 800 + i * 100);
          });

        trustObserver.unobserve(entry.target);
      });
    }, { threshold: 0.2 });

    const trustSidebar = document.querySelector<HTMLElement>('.trust-sidebar');
    if (trustSidebar) trustObserver.observe(trustSidebar);
  })();

  document.querySelectorAll<HTMLElement>('.trust-source-card').forEach(card => {
    const color = card.dataset.color;
    if (color) card.style.setProperty('--card-color', color);
  });

  (function() {
    const heroBg = document.getElementById('heroBg') as HTMLElement | null;
    if (!heroBg) return;

    let ticking = false;

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          const heroHeight = (heroBg.parentElement as HTMLElement).offsetHeight;

          if (scrollY < heroHeight) {
            const offset = scrollY * 0.4;
            heroBg.style.transform = `scale(1.04) translateY(${offset * 0.2}px)`;
          }
          ticking = false;
        });
        ticking = true;
      }
    });
  })();
</script>

