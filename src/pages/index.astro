---
import BaseLayout from '../layouts/BaseLayout.astro';
import qualityScores from '../data/quality-scores.json';
import cityRpp from '../data/city-rpp.json';

function computeScore(q: Record<string, number>) {
  const weights: Record<string, number> = {
    safety:       0.25,
    healthcare:   0.20,
    happiness:    0.15,
    hdi:          0.15,
    pollution:    0.08,
    unemployment: 0.07,
    internet:     0.05,
    traffic:      0.05,
  };
  let total = 0, totalWeight = 0;
  for (const [m, w] of Object.entries(weights)) {
    const val = (q as any)[m];
    if (val != null) { total += val * w; totalWeight += w; }
  }
  const pct = totalWeight > 0 ? Math.round((total / totalWeight) * 10) : 0;
  let label;
  if (pct >= 90) label = 'Outstanding destination';
  else if (pct >= 80) label = 'Excellent destination';
  else if (pct >= 70) label = 'Very good destination';
  else if (pct >= 60) label = 'Good destination';
  else if (pct >= 50) label = 'Solid destination';
  else if (pct >= 40) label = 'Mixed destination';
  else if (pct >= 30) label = 'Below average destination';
  else label = 'Needs careful research';
  return { pct, label };
}

let _mgIdx = 0;
function miniGaugeSVG(pct: number): string {
  const ARC = 135;
  const dashoffset = ARC - (pct / 100) * ARC;
  const angle = (pct / 100) * 180 - 90;
  const id = `mg${_mgIdx++}`;
  return `<svg viewBox="0 0 100 60" width="56" height="36" aria-hidden="true">
    <defs>
      <linearGradient id="${id}" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%"   stop-color="#DC2626"/>
        <stop offset="28%"  stop-color="#F59E0B"/>
        <stop offset="56%"  stop-color="#84CC16"/>
        <stop offset="100%" stop-color="#16A34A"/>
      </linearGradient>
    </defs>
    <path d="M 7 52 A 43 43 0 0 1 93 52" fill="none" stroke="#E2E8F0" stroke-width="7" stroke-linecap="round"/>
    <path d="M 7 52 A 43 43 0 0 1 93 52" fill="none" stroke="url(#${id})" stroke-width="7" stroke-linecap="round" stroke-dasharray="${ARC}" stroke-dashoffset="${dashoffset}"/>
    <g transform="rotate(${angle}, 50, 52)">
      <line x1="50" y1="52" x2="50" y2="17" stroke="#1E293B" stroke-width="1.5" stroke-linecap="round"/>
    </g>
    <circle cx="50" cy="52" r="4" fill="#1E293B"/>
    <circle cx="50" cy="52" r="1.5" fill="white" opacity="0.85"/>
  </svg>`;
}

const featuredCountries = [
  { name: "Portugal",       flag: '<span class="fi fi-pt feat-flag"></span>', iso2: "PT", slug: "portugal",        ppp: "1.8×", badge: "Most Popular",          featured: true },
  { name: "Spain",          flag: '<span class="fi fi-es feat-flag"></span>', iso2: "ES", slug: "spain",            ppp: "1.7×", badge: "Editor's Pick",         featured: false },
  { name: "Poland",         flag: '<span class="fi fi-pl feat-flag"></span>', iso2: "PL", slug: "poland",           ppp: "2.1×", badge: "Best Value Europe",      featured: false },
  { name: "Mexico",         flag: '<span class="fi fi-mx feat-flag"></span>', iso2: "MX", slug: "mexico",           ppp: "2.8×", badge: "Best Value Americas",    featured: false },
  { name: "Thailand",       flag: '<span class="fi fi-th feat-flag"></span>', iso2: "TH", slug: "thailand",         ppp: "3.1×", badge: "Digital Nomad Favorite", featured: false },
  { name: "Vietnam",        flag: '<span class="fi fi-vn feat-flag"></span>', iso2: "VN", slug: "vietnam",          ppp: "3.4×", badge: null,                     featured: false },
  { name: "Czech Republic", flag: '<span class="fi fi-cz feat-flag"></span>', iso2: "CZ", slug: "czech-republic",   ppp: "2.0×", badge: null,                     featured: false },
  { name: "Germany",        flag: '<span class="fi fi-de feat-flag"></span>', iso2: "DE", slug: "germany",          ppp: "1.4×", badge: "Strong Economy",          featured: false },
];

const qs = qualityScores.countries as Record<string, any>;
---

