  .trust-divider-fill.animated {
    width: 100%;
  }

  .trust-features {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    border-radius: 10px;
    font-size: 13px;
    color: #334155;
    font-weight: 500;
    transition: all 0.2s ease;
    opacity: 0;
    transform: translateX(-16px);
