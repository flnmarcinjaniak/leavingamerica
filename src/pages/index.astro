    opacity: 1;
    transform: translateY(0);
  }
  .mobility-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37,99,235,0.1);
  }
  .mobility-item.favorable { border-left-color: #16A34A; }
  .mobility-item.neutral   { border-left-color: #D97706; }
  .mobility-item.restricted { border-left-color: #DC2626; }
  .mobility-item-label {
    font-size: 9px;
