---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="LeavingAmerica — Calculate Your Savings Abroad"
  description="Find out how much further your money goes living abroad. Free calculator for Americans considering moving overseas."
>

  <!-- SECTION 1: HERO -->
  <section id="hero">
    <div class="hero-text">
      <h1>
        <span class="hero-h1-light">Your $90,000 salary</span>
        <span class="hero-h1-bold">is worth $200,000 in Lisbon</span>
      </h1>
      <p class="hero-subtext">
        1 in 5 Americans want to move abroad. Find out how much further your money goes.
      </p>
      <div class="hero-stats">
        <div class="hero-stat-item">
          <strong>180,000 Americans</strong>
          <span>emigrated in 2025</span>
        </div>
        <div class="hero-stat-item">
          <strong>$52,000/year</strong>
          <span>average savings for remote workers</span>
        </div>
      </div>
      <a href="/tools/salary" class="btn-pill btn-pill-primary">Calculate My Savings →</a>
    </div>

    <div class="hero-image-wrap">
      <img
        src="https://placehold.co/900x800/f1f5f9/475569?text=Hero+Image"
        alt="American passport and calculator"
        width="100%"
        height="100%"
      />
      <div class="hero-overlay"></div>
    </div>
  </section>

  <!-- SECTION 2: STATS BAR -->
  <section class="section-alt stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stats-item">
          <span class="stat-value">1 in 5</span>
          <p>Americans want to leave the US</p>
          <p class="stat-source">Source: Gallup 2025</p>
        </div>
        <div class="stats-item">
          <span class="stat-value">180,000</span>
          <p>Americans emigrated in 2025</p>
          <p class="stat-source">Source: Brookings Institution</p>
        </div>
        <div class="stats-item">
          <span class="stat-value">$52,000</span>
          <p>Average annual savings abroad</p>
          <p class="stat-source">Source: Remote work studies</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3: HOW IT WORKS -->
  <section class="section-white">
    <div class="container">
      <h2 class="section-heading">How It Works</h2>
      <div class="steps-grid">
        <div class="step-card">
          <p class="step-number">01</p>
          <h3>Enter Your Details</h3>
          <p>Tell us your current city, income and where you want to move.</p>
        </div>
        <div class="step-card">
          <p class="step-number">02</p>
          <h3>See Real Numbers</h3>
          <p>We calculate purchasing power, savings and quality of life score.</p>
        </div>
        <div class="step-card">
          <p class="step-number">03</p>
          <h3>Plan Your Move</h3>
          <p>Explore visa options, healthcare costs and top destinations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: TOP DESTINATIONS -->
  <section class="section-alt">
    <div class="container">
      <h2 class="section-heading">Where Americans Are Moving</h2>
      <div class="dest-grid">
        <a href="/move-to/portugal" class="dest-card">
          <img class="dest-flag-img" src="https://flagcdn.com/48x36/pt.png" alt="Portugal" />
          <h3 class="dest-name">Portugal</h3>
          <p class="dest-price">From $1,800/month</p>
          <p class="dest-desc">Mediterranean lifestyle at a fraction of US costs</p>
          <span class="dest-explore">Explore →</span>
        </a>
        <a href="/move-to/spain" class="dest-card">
          <img class="dest-flag-img" src="https://flagcdn.com/48x36/es.png" alt="Spain" />
          <h3 class="dest-name">Spain</h3>
          <p class="dest-price">From $2,000/month</p>
          <p class="dest-desc">Sunshine, culture and affordable city living</p>
          <span class="dest-explore">Explore →</span>
        </a>
        <a href="/move-to/mexico" class="dest-card">
          <img class="dest-flag-img" src="https://flagcdn.com/48x36/mx.png" alt="Mexico" />
          <h3 class="dest-name">Mexico</h3>
          <p class="dest-price">From $1,200/month</p>
          <p class="dest-desc">Close to home with dramatic cost savings</p>
          <span class="dest-explore">Explore →</span>
        </a>
        <a href="/move-to/germany" class="dest-card">
          <img class="dest-flag-img" src="https://flagcdn.com/48x36/de.png" alt="Germany" />
          <h3 class="dest-name">Germany</h3>
          <p class="dest-price">From $2,200/month</p>
          <p class="dest-desc">Strong economy and excellent quality of life</p>
          <span class="dest-explore">Explore →</span>
        </a>
        <a href="/move-to/italy" class="dest-card">
          <img class="dest-flag-img" src="https://flagcdn.com/48x36/it.png" alt="Italy" />
          <h3 class="dest-name">Italy</h3>
          <p class="dest-price">From $1,900/month</p>
          <p class="dest-desc">World-class food, history and lifestyle</p>
          <span class="dest-explore">Explore →</span>
        </a>
        <a href="/move-to/thailand" class="dest-card">
          <img class="dest-flag-img" src="https://flagcdn.com/48x36/th.png" alt="Thailand" />
          <h3 class="dest-name">Thailand</h3>
          <p class="dest-price">From $1,100/month</p>
          <p class="dest-desc">Tropical paradise for digital nomads</p>
          <span class="dest-explore">Explore →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 5: CTA BANNER -->
  <section class="section-white cta-section">
    <div class="container cta-inner">
      <h2>Ready to Calculate Your Escape?</h2>
      <p>Join thousands of Americans who discovered how far their money goes abroad.</p>
      <a href="/tools/salary" class="btn-pill btn-pill-primary cta-btn">
        Start Your Free Calculation →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ── */
  #hero {
    min-height: calc(100vh - 80px);
    display: grid;
    grid-template-columns: 4fr 6fr;
    overflow: visible;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 40px 40px 40px 60px;
  }

  .hero-text h1 {
    font-size: 64px;
    line-height: 1.1;
    display: flex;
    flex-direction: column;
    margin-bottom: 24px;
  }

  .hero-h1-light {
    font-weight: 400;
  }

  .hero-h1-bold {
    font-weight: 800;
  }

  .hero-subtext {
    font-size: 18px;
    color: #475569;
    margin-bottom: 40px;
    max-width: 420px;
    line-height: 1.6;
  }

  .hero-stats {
    display: flex;
    gap: 30px;
    margin-bottom: 40px;
  }

  .hero-stat-item {
    display: flex;
    flex-direction: column;
    font-size: 14px;
    color: #475569;
  }

  .hero-stat-item strong {
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 2px;
  }

  .hero-image-wrap {
    position: relative;
    overflow: hidden;
  }

  .hero-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 40%;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0) 0%, #ffffff 100%);
  }

  /* ── STATS BAR ── */
  .stats-section {
    padding: 60px 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    text-align: center;
  }

  .stats-item p {
    font-size: 15px;
    color: #475569;
    line-height: 1.5;
  }

  .stat-value {
    font-size: 48px;
    font-weight: 800;
    color: #0f172a;
    display: block;
    margin-bottom: 8px;
  }

  .stat-source {
    font-size: 11px;
    color: #94a3b8;
    margin-top: 4px;
  }

  /* ── HOW IT WORKS ── */
  .section-heading {
    font-size: 48px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 60px;
    color: #0f172a;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .step-card {
    background: white;
    border-radius: 12px;
    padding: 32px;
    border: 1px solid #e2e8f0;
  }

  .step-number {
    font-size: 13px;
    font-weight: 600;
    color: #2563eb;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .step-card h3 {
    font-size: 22px;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 12px;
  }

  .step-card p {
    font-size: 15px;
    color: #475569;
    line-height: 1.6;
  }

  /* ── DESTINATIONS ── */
  .dest-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .dest-card {
    background: white;
    box-shadow: var(--shadow-card);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
  }

  .dest-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .dest-flag-img {
    width: 48px;
    height: 36px;
    border-radius: 4px;
    margin-bottom: 16px;
    display: block;
    object-fit: cover;
  }

  .dest-name {
    font-size: 18px;
    font-weight: 700;
    color: #0f172a;
  }

  .dest-price {
    color: #16a34a;
    font-weight: 600;
    font-size: 15px;
    margin: 8px 0;
  }

  .dest-desc {
    font-size: 14px;
    color: #475569;
    line-height: 1.5;
    flex: 1;
  }

  .dest-explore {
    color: #2563eb;
    font-size: 14px;
    font-weight: 600;
    margin-top: 16px;
    display: block;
  }

  /* ── CTA BANNER ── */
  .cta-section {
    text-align: center;
  }

  .cta-inner h2 {
    font-size: 48px;
    font-weight: 800;
    margin-bottom: 16px;
    color: #0f172a;
  }

  .cta-inner p {
    color: #475569;
    margin-bottom: 40px;
    font-size: 18px;
  }

  .cta-btn {
    padding: 16px 40px;
    font-size: 16px;
  }
</style>
