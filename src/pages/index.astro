  .affiliate-title { font-size: 16px; font-weight: 700; color: #0F172A; margin-bottom: 8px; }
  .affiliate-desc { font-size: 14px; color: #64748B; margin-bottom: 0; line-height: 1.5; flex: 1; }
  .affiliate-btn { margin-top: 20px; }

  .affiliate-btn {
    display: inline-flex;
    padding: 10px 24px;
    background: #2563EB;
    color: white;
    border-radius: 100px;
    font-weight: 600;
    font-size: 14px;
