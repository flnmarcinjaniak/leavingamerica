  }
  .mini-gauge-of100 {
    font-size: 8px;
    font-weight: 600;
    opacity: 0.55;
    margin-left: 1px;
  }
  .card-mini-gauge {
    flex-shrink: 0;
    line-height: 0;
  }

  .country-ppp-hero {
    font-size: 30px;
    font-weight: 800;
    color: #2563EB;
    letter-spacing: -1px;
    line-height: 1;
    text-shadow: 0 0 20px rgba(37,99,235,0.25);
  }

  .country-ppp-label {
    font-size: 10px;
    color: #64748B;
    margin-top: 3px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }

  .country-card-body {
    padding: 14px 20px 18px;
  }

  .country-mini-bars { display: flex; flex-direction: column; gap: 6px; }

  .mini-bar-row {
    display: grid;
    grid-template-columns: 60px 1fr 20px;
    align-items: center;
    gap: 6px;
  }

  .mini-bar-label { font-size: 10px; color: #64748B; }

  .mini-bar-track {
    height: 3px;
    background: #F1F5F9;
    border-radius: 100px;
    overflow: hidden;
  }

  .mini-bar-fill { height: 100%; border-radius: 100px; }

  .mini-bar-score { font-size: 10px; color: #94A3B8; font-weight: 600; text-align: right; }
  .mini-bar-score { font-size: 10px; font-weight: 700; color: #0F172A; text-align: right; }

  /* ── HOW IT WORKS ── */
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr 32px 1fr 32px 1fr;
    align-items: center;
    gap: 30px;
  }

  .step-card {
    background: white;
    border-radius: 20px;
    padding: 36px 32px;
    border: 1px solid #e2e8f0;
    transition: box-shadow 0.2s, transform 0.2s;
    height: 100%;
    align-self: stretch;
  }

  .step-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    transform: translateY(-3px);
  }

  .step-icon {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 16px;
  }

  .step-icon img {
    width: 72px;
    height: 72px;
    object-fit: contain;
  }

  .step-num {
    font-size: 12px;
    font-weight: 700;
    color: #2563eb;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }

  .step-card h3 {
    font-size: 20px;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 10px;
  }

  .step-card p { font-size: 15px; color: #475569; line-height: 1.65; }

  /* ── TRUST SECTION ── */
  .trust-sources-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .trust-source-card {
    background: white;
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    padding: 24px 20px;
    text-align: center;
    transition: all 0.35s cubic-bezier(0.25,0.46,0.45,0.94);
    filter: grayscale(100%);
    opacity: 0.7;
    position: relative;
    overflow: hidden;
  }

  .trust-source-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 16px;
    background: var(--card-color, #2563EB);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .trust-source-card:hover {
    filter: grayscale(0%);
    opacity: 1;
    transform: translateY(-4px);
    border-color: var(--card-color, #2563EB);
    box-shadow: 0 12px 40px rgba(0,0,0,0.10);
  }

  .trust-source-card:hover::before {
    opacity: 0.12;
  }

  .trust-source-logo {
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .trust-source-logo img {
    max-height: 40px;
    max-width: 100%;
    object-fit: contain;
  }

  .trust-source-fallback {
    display: none;
    font-size: 13px;
    font-weight: 700;
    color: #0F172A;
  }

  .trust-source-desc {
    font-size: 12px;
    color: #64748B;
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .trust-source-link {
    font-size: 11px;
    font-weight: 600;
    color: #2563EB;
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .trust-source-card:hover .trust-source-link {
    opacity: 1;
  }

  .trust-source-card:nth-child(6):hover {
    border-color: #0EA5E9;
    background: linear-gradient(135deg, #F0F9FF 0%, #E0F2FE 100%);
  }
  .trust-source-card:nth-child(7):hover {
    border-color: #8B5CF6;
    background: linear-gradient(135deg, #FAF5FF 0%, #EDE9FE 100%);
  }
  .trust-source-card:nth-child(8):hover {
    border-color: #10B981;
    background: linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%);
  }

  /* ── FAQ ── */
  .faq-list {
    max-width: 720px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid #E2E8F0;
  }

  .faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    color: #0F172A;
    font-family: 'Manrope', sans-serif;
    gap: 16px;
  }

  .faq-question:hover { color: #2563EB; }

  .faq-icon {
    font-size: 20px;
    font-weight: 400;
    color: #94A3B8;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    line-height: 1;
  }

  .faq-item.open .faq-icon {
    transform: rotate(45deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .faq-answer p {
    padding-bottom: 20px;
    font-size: 15px;
    color: #475569;
    line-height: 1.7;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .hero-h1 { font-size: 48px; }
    .countries-grid { grid-template-columns: repeat(2, 1fr); }
    .trust-sources-grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 768px) {
    #hero { min-height: auto; }

    .hero-content {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 60px 0;
      gap: 40px;
    }

    .hero-text {
      align-items: center;
      text-align: center;
    }
    .hero-badges { justify-content: center; }
    .hero-example { justify-content: center; flex-wrap: wrap; }
    .trust-features { align-items: center; }

    .hero-h1 { font-size: 40px; letter-spacing: -1px; }
    .hero-sub { font-size: 16px; }
    .hero-visual { display: none; }

    .calc-grid { grid-template-columns: 1fr; gap: 40px; }
    /* Prevent translateX overflow on mobile */
    .calc-form, .calc-results { transform: none !important; opacity: 1 !important; transition: none !important; }
    /* Reduce card padding so content fits on narrow screens */
    .result-card { padding: 20px 16px; }
    /* Stack gauge + score details vertically on mobile */
    .score-display { flex-direction: column; align-items: flex-start; gap: 8px; }
    .quality-grid { grid-template-columns: 1fr; }
    .sources-grid { gap: 5px; }
    .section-h2 { font-size: 36px; }

    .affiliate-cards { grid-template-columns: 1fr; }
    .countries-grid { grid-template-columns: repeat(2, 1fr); }
    .financial-grid { flex-direction: column; }
    .financial-col { padding: 0; }
    .financial-divider { width: 100%; height: 1px; align-self: auto; margin: 20px 0; }
    .lifestyle-grid { grid-template-columns: 1fr; }
    .mobility-grid { grid-template-columns: 1fr; }
    .share-buttons { flex-direction: column; }
    .score-header { flex-direction: column; align-items: flex-start; gap: 4px; }
    .fire-tooltip-content { left: auto; right: 0; top: 28px; transform: none; width: 220px; }
    .steps-grid { grid-template-columns: 1fr; }
    .steps-arrow-between { display: none; }
    .steps-line-container { display: none; }
    .trust-sources-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .countries-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .hero-h1 { font-size: 32px; }
    .trust-sources-grid { grid-template-columns: 1fr; }
  }

  /* ══ MOTION ENHANCEMENTS ══ */

  /* 1. Scroll progress */
  #scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: linear-gradient(90deg, #2563EB, #22D3EE, #10B981);
    z-index: 9999;
    transition: width 0.1s linear;
    pointer-events: none;
  }

  /* 3. Extended reveal system — overrides initial .reveal */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s cubic-bezier(0.25,0.46,0.45,0.94),
                transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .reveal-left {
    opacity: 0;
    transform: translateX(-40px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal-right {
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal-scale {
    opacity: 0;
    transform: scale(0.92);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible,
  .reveal-left.visible,
  .reveal-right.visible,
  .reveal-scale.visible {
    opacity: 1;
    transform: none;
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }
  .reveal-delay-5 { transition-delay: 0.5s; }

  /* 5. Background orbs */
  .bg-orb {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
    filter: blur(80px);
  }
  .bg-orb-1 {
    width: 500px; height: 500px;
    background: rgba(37,99,235,0.06);
    top: 10%; right: 10%;
    animation: orbFloat1 12s ease-in-out infinite alternate;
  }
  .bg-orb-2 {
    width: 400px; height: 400px;
    background: rgba(34,211,238,0.04);
    bottom: 20%; left: 5%;
    animation: orbFloat2 16s ease-in-out infinite alternate;
  }
  .bg-orb-3 {
    width: 300px; height: 300px;
    background: rgba(16,185,129,0.04);
    top: 50%; left: 40%;
    animation: orbFloat3 20s ease-in-out infinite alternate;
  }
  @keyframes orbFloat1 {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(-60px,40px) scale(1.1); }
  }
  @keyframes orbFloat2 {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(40px,-60px) scale(0.9); }
  }
  @keyframes orbFloat3 {
    from { transform: translate(0,0) scale(1); }
    to   { transform: translate(-30px,30px) scale(1.05); }
  }

  /* 7. CTA animated gradient + ripple */
  #calcBtn,
  a[href="#salary-arbitrage"] {
    background-size: 200% 200% !important;
    background-image: linear-gradient(
      135deg,
      #1D4ED8 0%, #2563EB 25%,
      #0EA5E9 50%, #2563EB 75%,
      #1D4ED8 100%
    ) !important;
    animation: gradientShift 4s ease infinite;
    position: relative;
    overflow: hidden;
  }
  @keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  @keyframes rippleAnim {
    to { transform: scale(2.5); opacity: 0; }
  }

  /* 8. Steps connector */
  .steps-grid {
    position: relative;
  }

  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      position: relative;
    }
    .steps-grid::before {
      content: '';
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(
        180deg,
        #2563EB 0%,
        #22D3EE 100%
      );
      transform: translateX(-50%);
      z-index: 0;
    }
  }

  .steps-line-container {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    left: 0;
    right: 0;
    height: 2px;
    z-index: 0;
    background: #E2E8F0;
    overflow: visible;
    grid-column: 1 / -1;
  }

  .steps-line-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #2563EB, #22D3EE);
    transition: width 1.5s cubic-bezier(0.25,0.46,0.45,0.94);
    position: relative;
  }

  @media (max-width: 768px) {
    .steps-line {
      display: none;
    }
  }

  .steps-arrow-between {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #2563EB;
    font-size: 18px;
    opacity: 0;
    transition: opacity 0.3s ease;
    width: 32px;
    align-self: center;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  .steps-arrow-between.visible {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .steps-arrow-between {
      transform: rotate(90deg);
      width: auto;
      height: 32px;
      align-self: center;
    }
  }

  .step-card {
    position: relative;
    z-index: 1;
    background: white;
  }

  /* 9. Step number glow pulse */
  .step-num {
    animation: glowPulse 2s ease-in-out infinite alternate;
  }
  @keyframes glowPulse {
    from { text-shadow: 0 0 0 rgba(37,99,235,0); opacity: 0.7; }
    to   { text-shadow: 0 0 20px rgba(37,99,235,0.6); opacity: 1; }
  }

  /* 12. FAQ micro-animations */
  .faq-item { transition: transform 0.3s ease, border-color 0.3s ease; }
  .faq-item:hover {
    transform: translateX(4px);
    border-bottom-color: #2563EB;
  }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.25,0.46,0.45,0.94),
                opacity 0.3s ease;
    opacity: 0;
  }
  .faq-item.open .faq-answer { opacity: 1; }

  /* 13. Country cards */
  .country-card {
    transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94), box-shadow 0.3s ease, border-color 0.3s ease;
    position: relative;
  }

  .reveal-left {
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal-right {
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal-left.visible,
  .reveal-right.visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* 15. Affiliate cards hover glow */
  .affiliate-card {
    transition: all 0.3s ease;
    position: relative;
  }
  .affiliate-card::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(135deg, #2563EB, #22D3EE);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .affiliate-card:hover::after { opacity: 0.15; }
  .affiliate-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(37,99,235,0.2);
  }

  /* 16. Hero floating geometric shapes */
  .hero-shape {
    position: absolute;
    pointer-events: none;
    z-index: 1;
    opacity: 0.12;
  }
  .hero-shape-1 {
    width: 80px; height: 80px;
    border: 2px solid #2563EB;
    transform: rotate(45deg);
    top: 15%; left: 8%;
    animation: shapeFloat1 8s ease-in-out infinite;
  }
  .hero-shape-2 {
    width: 50px; height: 50px;
    border: 1.5px solid #22D3EE;
    border-radius: 50%;
    bottom: 25%; left: 15%;
    animation: shapeFloat2 10s ease-in-out infinite;
  }
  .hero-shape-3 {
    width: 60px; height: 60px;
    border: 1.5px solid #10B981;
    transform: rotate(30deg);
    top: 30%; left: 35%;
    animation: shapeFloat3 12s ease-in-out infinite;
  }
  @keyframes shapeFloat1 {
    0%,100% { transform: rotate(45deg) translate(0,0); }
    50%     { transform: rotate(55deg) translate(-10px,-15px); }
  }
  @keyframes shapeFloat2 {
    0%,100% { transform: translate(0,0); }
    50%     { transform: translate(10px,-20px); }
  }
  @keyframes shapeFloat3 {
    0%,100% { transform: rotate(30deg) translate(0,0); }
    50%     { transform: rotate(20deg) translate(8px,-12px); }
  }

  /* Lift hero-content above canvas */
  .hero-content { z-index: 2; }

  /* 17. Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    .reveal, .reveal-left, .reveal-right, .reveal-scale {
      opacity: 1 !important;
      transform: none !important;
    }
  }

  #hero-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 50%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  /* 18. Mobile — disable heavy animations */
  @media (max-width: 768px) {
    #hero-canvas { display: none; }
    .hero-shape  { display: none; }
    .bg-orb      { display: none; }
    .hero-bg-image {
      background-position: left bottom;
      animation: none;
    }
  }

  /* ── Calculator redesign ── */

  .calc-form-panel {
    position: sticky;
    top: 100px;
    align-self: flex-start;
  }

  .results-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .results-grid-2 .result-card {
