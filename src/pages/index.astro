  <section id="countries" class="section-white">
    <div class="container">
      <div class="section-header reveal">
        <h2 class="section-h2">Top Destinations for Americans</h2>
        <p class="destinations-subtitle">
          Ranked by purchasing power, quality of life
          and popularity among American expats
        </p>
      </div>
      <div class="countries-grid">
        {featuredCountries.map(({ name, flag, iso2, slug, ppp, badge, featured }) => {
          const q = qs[slug] || {};
          const computed = computeScore(q);
          const pct = (q.grade_percent != null && q.grade_label)
            ? q.grade_percent
            : computed.pct;
          const label = (q.grade_percent != null && q.grade_label)
            ? q.grade_label
            : computed.label;
          return (
            <div class={`country-card reveal${featured ? ' card-featured' : ''}`} data-iso2={iso2}>
              <div class="country-card-header">
                <div class="country-card-top">
                  <div class="country-flag" set:html={flag}></div>
                </div>
                <div class="country-name-score-row">
                  <div class="country-name">{name}</div>
                  <div class="card-mini-gauge-wrap">
                    <div class="mini-gauge-context">Quality of Life Score</div>
                    <div set:html={miniGaugeSVG(pct)}></div>
                    <div class="mini-gauge-pct" style={`color:${pct >= 70 ? '#16A34A' : pct >= 50 ? '#D97706' : '#DC2626'}`}>{pct}<span class="mini-gauge-of100">/100</span></div>
                    <div class="mini-gauge-label">{label.replace(' destination', '')}</div>
                  </div>
                </div>
                <div class="country-ppp-hero">{ppp}</div>
                <div class="country-ppp-label">purchasing power vs US dollar</div>
              </div>
              <div class="country-card-body">
                <div class="country-mini-bars">
                  <div class="mini-bar-row">
                    <span class="mini-bar-label">Safety</span>
                    <div class="mini-bar-track">
                      <div class="mini-bar-fill" style={`width:${(q.safety||0)*10}%; background:#10B981;`}></div>
                    </div>
                    <span class="mini-bar-score">{q.safety ?? '-'}</span>
                  </div>
                  <div class="mini-bar-row">
                    <span class="mini-bar-label">Healthcare</span>
                    <div class="mini-bar-track">
                      <div class="mini-bar-fill" style={`width:${(q.healthcare||0)*10}%; background:#3B82F6;`}></div>
                    </div>
                    <span class="mini-bar-score">{q.healthcare ?? '-'}</span>
                  </div>
                  <div class="mini-bar-row">
                    <span class="mini-bar-label">Happiness</span>
                    <div class="mini-bar-track">
                      <div class="mini-bar-fill" style={`width:${(q.happiness||0)*10}%; background:#F59E0B;`}></div>
                    </div>
                    <span class="mini-bar-score">{q.happiness ?? '-'}</span>
                  </div>
                </div>
              </div>
              {badge && <span class="country-badge">{badge}</span>}
            </div>
          );
        })}
      </div>
    </div>
