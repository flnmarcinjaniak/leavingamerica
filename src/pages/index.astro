  .share-fb { background: #1877F2; color: #fff; }
  .share-fb:hover { background: #1565D8; transform: translateY(-1px); }
  .share-reddit { background: #FF4500; color: #fff; }
  .share-reddit:hover { background: #e03d00; transform: translateY(-1px); }
