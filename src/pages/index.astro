  /* ── COUNTRY COMPARISON ── */
  .countries-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .country-card {
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    border: 1.5px solid #E2E8F0;
    background: white;
    transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94), box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .country-card:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 20px 50px rgba(37,99,235,0.15);
    background: linear-gradient(135deg, #F8FAFF 0%, #EEF4FF 100%);
  }

  .country-card::after {
    content: 'See your savings →';
    position: absolute;
    bottom: 16px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    color: #2563EB;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .country-card:hover::after {
    opacity: 1;
  }
  .country-card {
    position: relative;
    padding-bottom: 40px;
  }

  .destinations-subtitle {
    font-size: 15px;
    color: #64748B;
    margin-top: 8px;
    margin-bottom: 32px;
    text-align: center;
  }

  .country-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 6px 12px;
    border-radius: 999px;
    background: linear-gradient(135deg, #2563EB, #7C3AED);
    color: white;
    z-index: 2;
  }

  .card-featured {
    border: 2px solid rgba(37,99,235,0.3);
    box-shadow: 0 4px 20px rgba(37,99,235,0.1),
                0 0 0 1px rgba(37,99,235,0.05);
  }
  .card-featured:hover {
    box-shadow: 0 20px 50px rgba(37,99,235,0.2),
                0 0 0 2px rgba(37,99,235,0.15);
  }

  .country-card-header {
    background: linear-gradient(135deg, #F0F6FF 0%, #EEF2FF 100%);
    padding: 20px 20px 16px;
    border-bottom: 1px solid #E2E8F0;
  }

  .country-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .country-flag { display: block; }
  .feat-flag {
    display: block !important;
    width: 32px !important;
    height: 24px !important;
    border-radius: 4px !important;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(0,0,0,0.1) !important;
  }

  .country-grade-pill {
    display: inline-flex;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3px;
  }
  .country-grade-pct {
    background: #EFF6FF;
    color: #2563EB;
    font-weight: 700;
    font-size: 13px;
    padding: 4px 10px;
    border-radius: 100px;
  }

  .country-name-score-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 6px;
    margin-bottom: 4px;
  }
  .country-name {
    font-size: 17px;
    font-weight: 700;
    color: #0F172A;
  }
  .card-mini-gauge-wrap {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 0;
  }
  .mini-gauge-pct {
    font-size: 12px;
    font-weight: 800;
    line-height: 1;
    margin-top: 3px;
    font-family: 'Manrope', sans-serif;
  }
  .mini-gauge-label {
    font-size: 9px;
    font-weight: 600;
    color: #94A3B8;
    line-height: 1;
    margin-top: 2px;
    white-space: nowrap;
    font-family: 'Manrope', sans-serif;
  }
  .mini-gauge-context {
    font-size: 9px;
    font-weight: 700;
    color: #64748B;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 4px;
    white-space: nowrap;
    font-family: 'Manrope', sans-serif;
