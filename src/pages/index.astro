        const startAngle    = -90;
        const duration      = 1300;

        // Arc: CSS transition handles it — just set the final value
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            if (arc) arc.style.strokeDashoffset = String(ARC_LENGTH - filledLength);
          });
        });

        // Needle: manual rAF loop, same easeOutBack as Gauge.astro
        if (needle) {
          function easeOutBack(t) {
            const c1 = 1.5, c3 = c1 + 1;
            return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2);
          }
          const needleStart = performance.now();
          function animateNeedle(now) {
            const t = Math.min((now - needleStart) / duration, 1);
            const angle = startAngle + (targetAngle - startAngle) * easeOutBack(t);
            needle.setAttribute('transform', `rotate(${angle}, 100, 105)`);
            if (t < 1) requestAnimationFrame(animateNeedle);
          }
          requestAnimationFrame(animateNeedle);
        }

