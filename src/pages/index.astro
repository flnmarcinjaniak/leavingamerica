  /* FIRE TOOLTIP */
  .fire-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .fire-tooltip-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .fire-tooltip-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    background: #E2E8F0;
    color: #64748B;
    border-radius: 50%;
    font-size: 10px;
    font-weight: 700;
    cursor: help;
    font-style: italic;
  }
  .fire-tooltip-content {
    display: none;
    position: absolute;
    left: 24px;
    top: 50%;
    transform: translateY(-50%);
    background: #0F172A;
    color: white;
    font-size: 12px;
    line-height: 1.5;
    padding: 12px 14px;
    border-radius: 10px;
