---
import BaseLayout from '../layouts/BaseLayout.astro';
import qualityScoresData from '../data/quality-scores.json';

const NAMES: Record<string,string> = {
  'portugal':'Portugal','spain':'Spain','poland':'Poland','mexico':'Mexico',
  'thailand':'Thailand','germany':'Germany','japan':'Japan','croatia':'Croatia',
  'czech-republic':'Czech Republic','hungary':'Hungary','romania':'Romania',
  'bulgaria':'Bulgaria','vietnam':'Vietnam','south-korea':'South Korea',
  'australia':'Australia','new-zealand':'New Zealand','canada':'Canada',
  'ireland':'Ireland','netherlands':'Netherlands','france':'France',
  'argentina':'Argentina','ecuador':'Ecuador','morocco':'Morocco',
  'switzerland':'Switzerland','norway':'Norway','denmark':'Denmark',
  'sweden':'Sweden','belgium':'Belgium','austria':'Austria','finland':'Finland',
  'united-kingdom':'United Kingdom','singapore':'Singapore',
  'united-arab-emirates':'UAE','qatar':'Qatar','saudi-arabia':'Saudi Arabia',
  'iceland':'Iceland','india':'India','philippines':'Philippines','china':'China',
  'georgia':'Georgia','serbia':'Serbia','kenya':'Kenya','peru':'Peru',
  'brazil':'Brazil','chile':'Chile','albania':'Albania','sri-lanka':'Sri Lanka',
  'egypt':'Egypt','indonesia':'Indonesia','colombia':'Colombia',
  'costa-rica':'Costa Rica','panama':'Panama','malaysia':'Malaysia',
  'italy':'Italy','greece':'Greece','bahamas':'Bahamas','belize':'Belize',
  'bolivia':'Bolivia','cambodia':'Cambodia','cyprus':'Cyprus',
  'dominican-republic':'Dominican Republic','el-salvador':'El Salvador',
  'estonia':'Estonia','ghana':'Ghana','honduras':'Honduras','jamaica':'Jamaica',
  'kazakhstan':'Kazakhstan','latvia':'Latvia','lithuania':'Lithuania',
  'malta':'Malta','montenegro':'Montenegro','nepal':'Nepal',
  'nicaragua':'Nicaragua','north-macedonia':'North Macedonia','paraguay':'Paraguay',
  'rwanda':'Rwanda','slovakia':'Slovakia','slovenia':'Slovenia',
  'south-africa':'South Africa','taiwan':'Taiwan','turkey':'Turkey','uruguay':'Uruguay',
};

const ISO2: Record<string,string> = {
  'portugal':'pt','spain':'es','poland':'pl','mexico':'mx','thailand':'th',
  'germany':'de','japan':'jp','croatia':'hr','czech-republic':'cz','hungary':'hu',
  'romania':'ro','bulgaria':'bg','vietnam':'vn','south-korea':'kr','australia':'au',
  'new-zealand':'nz','canada':'ca','ireland':'ie','netherlands':'nl','france':'fr',
  'argentina':'ar','ecuador':'ec','morocco':'ma','switzerland':'ch','norway':'no',
  'denmark':'dk','sweden':'se','belgium':'be','austria':'at','finland':'fi',
  'united-kingdom':'gb','singapore':'sg','united-arab-emirates':'ae','qatar':'qa',
  'saudi-arabia':'sa','iceland':'is','india':'in','philippines':'ph','china':'cn',
  'georgia':'ge','serbia':'rs','kenya':'ke','peru':'pe','brazil':'br','chile':'cl',
  'albania':'al','sri-lanka':'lk','egypt':'eg','indonesia':'id','colombia':'co',
  'costa-rica':'cr','panama':'pa','malaysia':'my','italy':'it','greece':'gr',
  'bahamas':'bs','belize':'bz','bolivia':'bo','cambodia':'kh','cyprus':'cy',
  'dominican-republic':'do','el-salvador':'sv','estonia':'ee','ghana':'gh',
  'honduras':'hn','jamaica':'jm','kazakhstan':'kz','latvia':'lv','lithuania':'lt',
  'malta':'mt','montenegro':'me','nepal':'np','nicaragua':'ni',
  'north-macedonia':'mk','paraguay':'py','rwanda':'rw','slovakia':'sk',
  'slovenia':'si','south-africa':'za','taiwan':'tw','turkey':'tr','uruguay':'uy',
};

const qs = qualityScoresData.countries as Record<string, any>;
const budgetData = Object.entries(qs)
  .filter(([slug, d]) => d.budget_single && d.budget_couple && NAMES[slug] && ISO2[slug])
  .map(([slug, d]) => ({
    slug,
    name: NAMES[slug],
    iso2: ISO2[slug],
    bs: d.budget_single,
    bc: d.budget_couple,
  }));

const budgetJSON = JSON.stringify(budgetData);
const countryCount = budgetData.length;

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': [
    {
      '@type': 'Question',
      'name': 'How is my monthly runway calculated?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'We multiply the country\'s average monthly cost of living by your lifestyle factor (Lean 0.75x, Normal 1.0x, Comfortable 1.35x), then subtract your monthly income to get your net monthly burn rate. Dividing your total savings by that burn rate gives your runway in months.'
      }
    },
    {
      '@type': 'Question',
      'name': 'What does Indefinite mean in the results?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Indefinite means your monthly income covers or exceeds the cost of living in that country at your chosen lifestyle level. Your savings remain intact indefinitely, which is the threshold for location-independent financial independence.'
      }
    },
    {
      '@type': 'Question',
      'name': 'Do these monthly costs include rent?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Yes. The figures represent a realistic all-in monthly budget including rent, food, transport, utilities, and basic everyday spending. They reflect mid-range living rather than backpacker minimums or luxury expat lifestyles.'
      }
    },
    {
      '@type': 'Question',
      'name': 'Should I choose Lean, Normal, or Comfortable?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Lean (0.75x) works for shared housing, cooking most meals at home, and minimal extras. Normal (1.0x) is a realistic mid-range baseline. Comfortable (1.35x) covers a private apartment in a good neighborhood, dining out regularly, and occasional local travel. Most people moving abroad for the first time land between Normal and Comfortable.'
      }
    },
    {
      '@type': 'Question',
      'name': 'Can I include remote work or freelance income?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Yes. The Monthly income field accepts any recurring income including remote salary, freelance revenue, Social Security, pension payments, or investment distributions. The calculator subtracts this from monthly costs before computing your runway.'
      }
    }
  ]
});
---

<BaseLayout
  title="Runway Calculator: How Long Can Your Savings Last Abroad?"
