---
import BaseLayout from '../../layouts/BaseLayout.astro';
import qualityScoresData from '../../data/quality-scores.json';

const NAMES: Record<string,string> = {
  'portugal':'Portugal','spain':'Spain','poland':'Poland','mexico':'Mexico',
  'thailand':'Thailand','germany':'Germany','japan':'Japan','croatia':'Croatia',
  'czech-republic':'Czech Republic','hungary':'Hungary','romania':'Romania',
  'bulgaria':'Bulgaria','vietnam':'Vietnam','south-korea':'South Korea',
  'australia':'Australia','new-zealand':'New Zealand','canada':'Canada',
  'ireland':'Ireland','netherlands':'Netherlands','france':'France',
  'argentina':'Argentina','ecuador':'Ecuador','morocco':'Morocco',
  'switzerland':'Switzerland','norway':'Norway','denmark':'Denmark',
  'sweden':'Sweden','belgium':'Belgium','austria':'Austria','finland':'Finland',
  'united-kingdom':'United Kingdom','singapore':'Singapore',
  'united-arab-emirates':'UAE','qatar':'Qatar','saudi-arabia':'Saudi Arabia',
  'iceland':'Iceland','india':'India','philippines':'Philippines','china':'China',
  'georgia':'Georgia','serbia':'Serbia','kenya':'Kenya','peru':'Peru',
  'brazil':'Brazil','chile':'Chile','albania':'Albania','sri-lanka':'Sri Lanka',
  'egypt':'Egypt','indonesia':'Indonesia','colombia':'Colombia',
  'costa-rica':'Costa Rica','panama':'Panama','malaysia':'Malaysia',
  'italy':'Italy','greece':'Greece','bahamas':'Bahamas','belize':'Belize',
  'bolivia':'Bolivia','cambodia':'Cambodia','cyprus':'Cyprus',
  'dominican-republic':'Dominican Republic','el-salvador':'El Salvador',
  'estonia':'Estonia','ghana':'Ghana','honduras':'Honduras','jamaica':'Jamaica',
  'kazakhstan':'Kazakhstan','latvia':'Latvia','lithuania':'Lithuania',
  'malta':'Malta','montenegro':'Montenegro','nepal':'Nepal',
  'nicaragua':'Nicaragua','north-macedonia':'North Macedonia','paraguay':'Paraguay',
  'rwanda':'Rwanda','slovakia':'Slovakia','slovenia':'Slovenia',
  'south-africa':'South Africa','taiwan':'Taiwan','turkey':'Turkey','uruguay':'Uruguay',
};
const ISO2: Record<string,string> = {
  'portugal':'pt','spain':'es','poland':'pl','mexico':'mx','thailand':'th',
  'germany':'de','japan':'jp','croatia':'hr','czech-republic':'cz','hungary':'hu',
  'romania':'ro','bulgaria':'bg','vietnam':'vn','south-korea':'kr','australia':'au',
  'new-zealand':'nz','canada':'ca','ireland':'ie','netherlands':'nl','france':'fr',
  'argentina':'ar','ecuador':'ec','morocco':'ma','switzerland':'ch','norway':'no',
  'denmark':'dk','sweden':'se','belgium':'be','austria':'at','finland':'fi',
  'united-kingdom':'gb','singapore':'sg','united-arab-emirates':'ae','qatar':'qa',
  'saudi-arabia':'sa','iceland':'is','india':'in','philippines':'ph','china':'cn',
  'georgia':'ge','serbia':'rs','kenya':'ke','peru':'pe','brazil':'br','chile':'cl',
  'albania':'al','sri-lanka':'lk','egypt':'eg','indonesia':'id','colombia':'co',
  'costa-rica':'cr','panama':'pa','malaysia':'my','italy':'it','greece':'gr',
  'bahamas':'bs','belize':'bz','bolivia':'bo','cambodia':'kh','cyprus':'cy',
  'dominican-republic':'do','el-salvador':'sv','estonia':'ee','ghana':'gh',
  'honduras':'hn','jamaica':'jm','kazakhstan':'kz','latvia':'lv','lithuania':'lt',
  'malta':'mt','montenegro':'me','nepal':'np','nicaragua':'ni',
  'north-macedonia':'mk','paraguay':'py','rwanda':'rw','slovakia':'sk',
  'slovenia':'si','south-africa':'za','taiwan':'tw','turkey':'tr','uruguay':'uy',
};

const qs = qualityScoresData.countries as Record<string, any>;
const all = Object.entries(qs);
const totalCountries = all.length;

const fire = (budget: number) => budget * 12 / 0.04;

type Row = { slug: string; name: string; iso2: string; single: number; couple: number; fireNum: number; tax: string; nomad: boolean };
const ranked: Row[] = all
  .filter(([slug, d]) => d.budget_single && d.budget_couple && NAMES[slug] && ISO2[slug])
  .map(([slug, d]) => ({
    slug, name: NAMES[slug], iso2: ISO2[slug],
    single: d.budget_single as number, couple: d.budget_couple as number,
    fireNum: Math.round(fire(d.budget_single as number)), tax: d.tax_system || 'unknown',
    nomad: !!d.nomad_visa,
  }))
  .sort((a, b) => a.single - b.single);

const budgetCount = ranked.length;
const cheapest = ranked[0];
const priciest = ranked[ranked.length - 1];
const median = ranked[Math.floor(ranked.length / 2)].single;
const under1500 = ranked.filter(r => r.single < 1500).length;
const under1000 = ranked.filter(r => r.single < 1000).length;
const coupleRatioPct = Math.round(
  (ranked.reduce((s, r) => s + r.couple / r.single, 0) / budgetCount - 1) * 100
);
const fireUnder500k = ranked.filter(r => r.fireNum < 500000).length;
const usFire = 3500 * 12 / 0.04;

const taxCounts: Record<string, number> = {};
ranked.forEach(r => { taxCounts[r.tax] = (taxCounts[r.tax] || 0) + 1; });
const worldwideN = taxCounts['worldwide'] || 0;
const territorialN = taxCounts['territorial'] || 0;
const zeroN = taxCounts['zero'] || 0;
const taxTotal = worldwideN + territorialN + zeroN;
const zeroTaxCountries = ranked.filter(r => r.tax === 'zero').map(r => r);
const nomadVisaCount = all.filter(([, d]) => d.nomad_visa).length;

// leaderboard: cheapest 12
const leaderboard = ranked.slice(0, 12);
const lbMax = leaderboard[leaderboard.length - 1].single;

// runway on $100k for a spread of countries
const runwaySlugs = ['egypt','vietnam','thailand','mexico','portugal','spain','switzerland'];
const runwayBars = runwaySlugs
  .map(s => ranked.find(r => r.slug === s))
  .filter((r): r is Row => !!r)
  .map(r => ({ ...r, years: +(100000 / r.single / 12).toFixed(1) }));
const runwayMax = Math.max(...runwayBars.map(r => r.years));

// FIRE comparison bars (cheapest first, US last/tallest)
const fireSlugs = ['egypt','thailand','mexico','portugal'];
const fireBars = [
  ...fireSlugs.map(s => ranked.find(r => r.slug === s)).filter((r): r is Row => !!r)
    .map(r => ({ name: r.name, iso2: r.iso2, value: r.fireNum, isUs: false })),
  { name: 'United States', iso2: 'us', value: usFire, isUs: true },
];
const fireMax = usFire;

const pb = (slug: string) => qs[slug]?.budget_single as number;
const updated = 'July 2026';

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': [
    { '@type': 'Question', 'name': 'How many Americans live abroad?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Estimates range from 5 to 9 million US citizens living outside the United States. A 2026 US Census Bureau analysis estimated that around 180,000 Americans moved abroad in the past year alone.' } },
    { '@type': 'Question', 'name': 'What is the cheapest country for Americans to live in?', 'acceptedAnswer': { '@type': 'Answer', 'text': `Among the ${budgetCount} countries tracked by LeavingAmerica.co, Egypt has the lowest baseline cost at about $700 per month for a single person. India, Vietnam, and Sri Lanka also come in under $1,000 per month.` } },
    { '@type': 'Question', 'name': 'How much money do you need to retire abroad?', 'acceptedAnswer': { '@type': 'Answer', 'text': `Using the 4% withdrawal rule, retiring in the cheapest tracked countries requires a portfolio of about $210,000, compared with roughly $1.05 million for a typical $3,500-per-month lifestyle in the United States. In ${fireUnder500k} of ${budgetCount} tracked countries, the required portfolio is below $500,000.` } },
    { '@type': 'Question', 'name': 'Which countries have no income tax for Americans?', 'acceptedAnswer': { '@type': 'Answer', 'text': `Of the countries tracked, ${zeroN} levy no personal income tax at all: ${zeroTaxCountries.map(c => c.name).join(', ')}. US citizens still owe US federal tax on worldwide income regardless of where they live.` } },
    { '@type': 'Question', 'name': 'Do Americans abroad still pay US taxes?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Yes. The United States taxes citizens on worldwide income regardless of where they live. The Foreign Earned Income Exclusion can shield up to $130,000 of foreign-earned income (2025 tax year), and foreign accounts over $10,000 combined must be reported via FBAR.' } },
    { '@type': 'Question', 'name': 'Where do most Americans move when they leave the US?', 'acceptedAnswer': { '@type': 'Answer', 'text': 'Mexico hosts the largest American community abroad at roughly 1.2 million people, followed by Canada with more than 250,000. Portugal has seen the fastest recent growth, with American relocations nearly tripling since 2024.' } },
    { '@type': 'Question', 'name': 'How many countries offer a digital nomad visa?', 'acceptedAnswer': { '@type': 'Answer', 'text': `${nomadVisaCount} of the ${totalCountries} countries tracked by LeavingAmerica.co offer an official digital nomad visa, giving remote workers a legal medium-term path to live there without employer sponsorship.` } },
  ],
});
---

<BaseLayout
  title="Americans Moving Abroad: Statistics & Data (2026)"
  description="How many Americans are moving abroad, what it costs to live in 74 countries, retirement math, no-tax countries, and digital nomad visas. Sourced, citable data, updated 2026."
  ogTitle="Americans Moving Abroad: 30+ Statistics for 2026"
>
  <script type="application/ld+json" set:html={faqSchema} />

<style is:global>
:root { --stx-ease: cubic-bezier(0.22, 1, 0.36, 1); }

/* ═══ HERO ═══ */
.stx-hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #0a1120 0%, #10203f 48%, #0b1830 100%);
  color: #fff;
  padding: 92px 0 78px;
  text-align: center;
}
.stx-orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; }
.stx-orb-1 { width: 640px; height: 640px; background: #2563eb; opacity: 0.42; top: -220px; left: -120px; }
.stx-orb-2 { width: 520px; height: 520px; background: #0891b2; opacity: 0.34; bottom: -180px; right: -120px; }
.stx-orb-3 { width: 340px; height: 340px; background: #6366f1; opacity: 0.28; top: -40px; right: 16%; }
.stx-dots {
  position: absolute; inset: 0;
  background-image: radial-gradient(rgba(255,255,255,0.06) 1px, transparent 1px);
  background-size: 30px 30px; pointer-events: none;
  mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 40%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 40%, transparent 100%);
}
.stx-hero-inner { max-width: 900px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
.stx-pill {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 16px; background: rgba(59,130,246,0.16);
  border: 1px solid rgba(96,165,250,0.35); border-radius: 30px;
  font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  color: #93c5fd; margin-bottom: 24px;
}
.stx-pill-dot { width: 7px; height: 7px; border-radius: 50%; background: #34d399; box-shadow: 0 0 0 0 rgba(52,211,153,0.7); animation: stx-pulse 2s infinite; }
@keyframes stx-pulse { 0% { box-shadow: 0 0 0 0 rgba(52,211,153,0.6); } 70% { box-shadow: 0 0 0 8px rgba(52,211,153,0); } 100% { box-shadow: 0 0 0 0 rgba(52,211,153,0); } }
.stx-hero h1 {
  font-size: clamp(30px, 5.4vw, 54px); font-weight: 800; letter-spacing: -0.03em;
  line-height: 1.08; margin: 0 0 18px;
  background: linear-gradient(180deg, #ffffff 0%, #bcd2f5 100%);
  -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
}
.stx-hero-sub { font-size: clamp(15px, 2.1vw, 18px); color: rgba(255,255,255,0.66); max-width: 620px; margin: 0 auto; line-height: 1.6; }
.stx-hero-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 46px; }
.stx-hs {
  background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px; padding: 22px 14px 18px; backdrop-filter: blur(8px);
}
.stx-hs-num { font-size: clamp(24px, 3.4vw, 36px); font-weight: 800; letter-spacing: -0.02em; line-height: 1; color: #fff; }
.stx-hs-num.grad { background: linear-gradient(120deg, #60a5fa, #22d3ee); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
.stx-hs-label { font-size: 12px; color: rgba(255,255,255,0.55); margin-top: 8px; line-height: 1.35; }
.stx-meta { font-size: 13px; color: rgba(255,255,255,0.4); margin-top: 36px; }
.stx-meta a { color: rgba(255,255,255,0.55); }

/* ═══ BODY ═══ */
.stx-body { background: #f8fafc; }
.stx-section { padding: 60px 0 12px; }
.stx-section:last-of-type { padding-bottom: 72px; }
.stx-wrap { max-width: 900px; margin: 0 auto; padding: 0 24px; }
.stx-eyebrow { font-size: 11px; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: #2563eb; margin: 0 0 8px; }
.stx-section h2 { font-size: clamp(21px, 3.2vw, 30px); font-weight: 800; color: #0f172a; letter-spacing: -0.02em; margin: 0 0 6px; line-height: 1.2; }
.stx-section-sub { font-size: 14px; color: #64748b; margin: 0 0 28px; max-width: 620px; }

/* reveal */
.stx-reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.7s var(--stx-ease), transform 0.7s var(--stx-ease); }
.stx-reveal.in { opacity: 1; transform: none; }

/* stat cards grid */
.stx-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.stx-card {
  position: relative; background: #fff; border: 1px solid #e6ebf2; border-radius: 16px;
  padding: 24px 24px 20px; overflow: hidden;
  transition: transform 0.25s var(--stx-ease), box-shadow 0.25s var(--stx-ease), border-color 0.25s;
}
.stx-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #2563eb, #22d3ee); transform: scaleX(0); transform-origin: left; transition: transform 0.5s var(--stx-ease); }
.stx-card.in::before { transform: scaleX(1); }
.stx-card:hover { transform: translateY(-3px); box-shadow: 0 14px 34px rgba(15,23,42,0.09); border-color: #cbd8e8; }
.stx-num { font-size: 30px; font-weight: 800; color: #0f172a; letter-spacing: -0.02em; line-height: 1.05; margin-bottom: 8px; }
.stx-num.blue { color: #1d4ed8; }
.stx-num.green { color: #059669; }
.stx-num.amber { color: #b45309; }
.stx-card p { font-size: 14px; color: #334155; line-height: 1.62; margin: 0; }
.stx-src { display: block; font-size: 12px; color: #94a3b8; margin-top: 12px; }
.stx-src a { color: #94a3b8; }

/* CTA / cite bands */
.stx-cta { background: linear-gradient(135deg, #eff6ff, #eef2ff); border: 1px solid #dbe4fb; border-radius: 16px; padding: 20px 24px; margin-top: 30px; font-size: 14px; color: #334155; line-height: 1.6; }
.stx-cta a { color: #2563eb; font-weight: 700; text-decoration: none; }
.stx-cta a:hover { text-decoration: underline; }
.stx-cite { background: #0f1e38; color: #cbd9f0; border-radius: 16px; padding: 24px 26px; font-size: 14px; line-height: 1.65; margin-top: 40px; }
.stx-cite strong { color: #fff; }
.stx-cite a { color: #7dd3fc; }

/* ═══ BAR CHART (leaderboard / runway) ═══ */
.stx-chart { background: #fff; border: 1px solid #e6ebf2; border-radius: 18px; padding: 26px 26px 22px; }
.stx-bar-row { display: grid; grid-template-columns: 148px 1fr auto; align-items: center; gap: 14px; padding: 9px 0; }
.stx-bar-label { display: flex; align-items: center; gap: 9px; font-size: 13.5px; font-weight: 600; color: #1e293b; min-width: 0; }
.stx-bar-label .fi { width: 22px; height: 16px; border-radius: 3px; flex-shrink: 0; box-shadow: 0 0 0 1px rgba(0,0,0,0.12); }
.stx-bar-label span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.stx-bar-track { height: 26px; background: #f1f5f9; border-radius: 8px; overflow: hidden; }
.stx-bar-fill { height: 100%; width: 0; border-radius: 8px; transition: width 1.1s var(--stx-ease); }
.stx-bar-fill.green { background: linear-gradient(90deg, #10b981, #34d399); }
.stx-bar-fill.blue { background: linear-gradient(90deg, #2563eb, #22d3ee); }
.stx-bar-fill.us { background: linear-gradient(90deg, #e11d48, #fb7185); }
.stx-bar-val { font-size: 13.5px; font-weight: 800; color: #0f172a; white-space: nowrap; }
.stx-chart-note { font-size: 12.5px; color: #94a3b8; margin: 16px 0 0; }

/* ═══ TAX STACKED BAR ═══ */
.stx-tax-bar { display: flex; height: 42px; border-radius: 12px; overflow: hidden; border: 1px solid #e2e8f0; background: #f1f5f9; }
.stx-tax-seg { height: 100%; width: 0; transition: width 1.1s var(--stx-ease); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 12px; font-weight: 800; }
.stx-tax-seg.world { background: linear-gradient(90deg, #475569, #64748b); }
.stx-tax-seg.terr { background: linear-gradient(90deg, #0891b2, #22d3ee); }
.stx-tax-seg.zero { background: linear-gradient(90deg, #059669, #34d399); }
.stx-tax-legend { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 16px; }
.stx-tl { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #334155; }
.stx-tl-dot { width: 12px; height: 12px; border-radius: 4px; }
.stx-tl-dot.world { background: #64748b; } .stx-tl-dot.terr { background: #22d3ee; } .stx-tl-dot.zero { background: #34d399; }
.stx-zero-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
.stx-zchip { display: inline-flex; align-items: center; gap: 7px; padding: 7px 13px; background: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 22px; font-size: 13px; color: #065f46; font-weight: 600; text-decoration: none; }
.stx-zchip:hover { background: #d1fae5; }
.stx-zchip .fi { width: 18px; height: 13px; border-radius: 2px; box-shadow: 0 0 0 1px rgba(0,0,0,0.1); }

/* ═══ NOMAD CHIPS ═══ */
.stx-nomad-chips { display: flex; flex-wrap: wrap; gap: 8px; }
.stx-nchip { display: inline-flex; align-items: center; gap: 7px; padding: 7px 13px; background: #fff; border: 1px solid #e2e8f0; border-radius: 22px; font-size: 13px; color: #334155; font-weight: 600; text-decoration: none; }
.stx-nchip:hover { border-color: #93c5fd; background: #eff6ff; }
.stx-nchip .fi { width: 18px; height: 13px; border-radius: 2px; box-shadow: 0 0 0 1px rgba(0,0,0,0.1); }

/* ═══ FULL TABLE ═══ */
.stx-table-tools { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
.stx-search { position: relative; flex: 1; min-width: 220px; }
.stx-search input {
  width: 100%; padding: 11px 14px 11px 38px; font-size: 14px; font-family: inherit;
  border: 1.5px solid #cbd5e1; border-radius: 10px; outline: none; box-sizing: border-box; color: #0f172a;
  transition: border-color 0.15s, box-shadow 0.15s; background: #fff;
}
.stx-search input:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.12); }
.stx-search svg { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: #94a3b8; }
.stx-search-count { font-size: 13px; color: #94a3b8; white-space: nowrap; }
.stx-table-scroll { overflow-x: auto; border: 1px solid #e6ebf2; border-radius: 14px; background: #fff; }
table.stx-table { width: 100%; border-collapse: collapse; font-size: 13.5px; min-width: 560px; }
.stx-table thead th { position: sticky; top: 0; background: #0f1e38; color: #cbd9f0; font-weight: 700; text-align: left; padding: 13px 16px; font-size: 12px; letter-spacing: 0.02em; white-space: nowrap; }
.stx-table thead th.num { text-align: right; }
.stx-table tbody td { padding: 11px 16px; border-top: 1px solid #eef2f7; color: #334155; }
.stx-table tbody td.num { text-align: right; font-variant-numeric: tabular-nums; font-weight: 600; color: #0f172a; }
.stx-table tbody tr:hover { background: #f8fafc; }
.stx-table tbody tr:nth-child(even) { background: #fcfdff; }
.stx-table tbody tr:nth-child(even):hover { background: #f8fafc; }
.stx-tc-name { display: flex; align-items: center; gap: 10px; }
.stx-tc-name a { color: #1e293b; text-decoration: none; font-weight: 600; }
.stx-tc-name a:hover { color: #2563eb; }
.stx-tc-name .fi { width: 22px; height: 16px; border-radius: 3px; flex-shrink: 0; box-shadow: 0 0 0 1px rgba(0,0,0,0.12); }
.stx-tax-tag { display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 9px; border-radius: 20px; white-space: nowrap; }
.stx-tax-tag.worldwide { background: #f1f5f9; color: #475569; }
.stx-tax-tag.territorial { background: #ecfeff; color: #0e7490; }
.stx-tax-tag.zero { background: #ecfdf5; color: #047857; }
.stx-tax-tag.unknown { background: #f1f5f9; color: #94a3b8; }
.stx-noresults { display: none; text-align: center; padding: 32px; color: #94a3b8; font-size: 14px; }

/* ═══ FAQ ═══ */
.stx-faq { margin-top: 14px; }
.stx-faq-item { border-top: 1px solid #e2e8f0; }
.stx-faq-item:last-child { border-bottom: 1px solid #e2e8f0; }
.stx-faq-q { display: flex; align-items: center; justify-content: space-between; gap: 18px; width: 100%; background: none; border: none; padding: 18px 0; font-size: 15px; font-weight: 700; color: #0f172a; cursor: pointer; text-align: left; font-family: inherit; }
.stx-faq-q:hover { color: #2563eb; }
.stx-faq-ic { font-size: 22px; font-weight: 400; color: #94a3b8; flex-shrink: 0; transition: transform 0.2s; width: 24px; text-align: center; }
.stx-faq-q[aria-expanded="true"] .stx-faq-ic { transform: rotate(45deg); }
.stx-faq-a { padding-bottom: 18px; }
.stx-faq-a p { font-size: 14px; color: #475569; line-height: 1.72; margin: 0; }

@media (max-width: 720px) {
  .stx-hero-stats { grid-template-columns: 1fr 1fr; }
  .stx-grid { grid-template-columns: 1fr; }
  .stx-bar-row { grid-template-columns: 118px 1fr auto; gap: 10px; }
  .stx-bar-label { font-size: 12.5px; }
}
@media (prefers-reduced-motion: reduce) {
  .stx-reveal { opacity: 1; transform: none; transition: none; }
  .stx-bar-fill, .stx-tax-seg { transition: none; }
  .stx-pill-dot { animation: none; }
}
</style>

<!-- HERO -->
