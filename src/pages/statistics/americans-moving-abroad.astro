      <div class="stx-hs"><div class="stx-hs-num" data-count="180000" data-suffix="+">0</div><div class="stx-hs-label">Americans moved abroad last year</div></div>
      <div class="stx-hs"><div class="stx-hs-num grad" data-count="42" data-suffix="%">0</div><div class="stx-hs-label">have considered relocating</div></div>
      <div class="stx-hs"><div class="stx-hs-num" data-count="700" data-prefix="$">0</div><div class="stx-hs-label">cheapest monthly cost of living</div></div>
