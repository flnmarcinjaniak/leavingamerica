<script>
  var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── reveal on scroll ──
  var revEls = Array.prototype.slice.call(document.querySelectorAll('.stx-reveal'));
  if (reduce) {
    revEls.forEach(function (el) { el.classList.add('in'); });
  } else {
    var revObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('in'); revObs.unobserve(e.target); } });
    }, { threshold: 0.12 });
    revEls.forEach(function (el) { revObs.observe(el); });
  }

  // ── count-up ──
  function fmt(n) { return Math.round(n).toLocaleString('en-US'); }
  function animateCount(el) {
    var target = parseFloat(el.getAttribute('data-count')) || 0;
    var prefix = el.getAttribute('data-prefix') || '';
    var suffix = el.getAttribute('data-suffix') || '';
    if (reduce) { el.textContent = prefix + fmt(target) + suffix; return; }
    var dur = 1300, start = null;
    function step(ts) {
      if (!start) start = ts;
      var p = Math.min((ts - start) / dur, 1);
      var eased = 1 - Math.pow(1 - p, 3);
      el.textContent = prefix + fmt(target * eased) + suffix;
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = prefix + fmt(target) + suffix;
    }
    requestAnimationFrame(step);
  }
  var countEls = Array.prototype.slice.call(document.querySelectorAll('[data-count]'));
  var countObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) { if (e.isIntersecting) { animateCount(e.target); countObs.unobserve(e.target); } });
  }, { threshold: 0.6 });
  countEls.forEach(function (el) { countObs.observe(el); });

  // ── bar fills (leaderboard, runway, fire, tax) ──
  var barEls = Array.prototype.slice.call(document.querySelectorAll('[data-bar]'));
  function fillBar(el) {
    var w = el.getAttribute('data-bar') + '%';
    if (reduce) { el.style.width = w; return; }
    requestAnimationFrame(function () { el.style.width = w; });
  }
  var barObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) { if (e.isIntersecting) { fillBar(e.target); barObs.unobserve(e.target); } });
  }, { threshold: 0.4 });
  barEls.forEach(function (el) { barObs.observe(el); });

  // ── table search ──
  var search = document.getElementById('stx-tbl-search');
  var rows = Array.prototype.slice.call(document.querySelectorAll('#stx-tbl-body tr'));
  var countEl = document.getElementById('stx-tbl-count');
  var noneEl = document.getElementById('stx-tbl-none');
  if (search) {
    search.addEventListener('input', function () {
      var q = search.value.trim().toLowerCase();
      var shown = 0;
      rows.forEach(function (tr) {
        var match = tr.getAttribute('data-name').indexOf(q) !== -1;
        tr.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      countEl.textContent = shown + (shown === 1 ? ' country' : ' countries');
      noneEl.style.display = shown === 0 ? 'block' : 'none';
    });
  }

  // ── FAQ accordion ──
  Array.prototype.slice.call(document.querySelectorAll('.stx-faq-q')).forEach(function (btn) {
    btn.addEventListener('click', function () {
      var open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      var body = btn.nextElementSibling;
      body.hidden = open;
      btn.querySelector('.stx-faq-ic').textContent = open ? '+' : '×';
    });
  });
</script>

