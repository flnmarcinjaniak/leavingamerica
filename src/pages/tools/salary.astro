---
import BaseLayout from '../../layouts/BaseLayout.astro';
import qualityScores from '../../data/quality-scores.json';
import cityRpp from '../../data/city-rpp.json';
---

<BaseLayout
  title="Lifestyle Arbitrage Calculator — LeavingAmerica"
  description="Calculate exactly how much you save by moving abroad. Powered by World Bank PPP and BEA Regional Price Parity data."
>
  <section class="section-white">
    <div class="container">
      <div class="calc-grid">

        <!-- LEFT COLUMN: Form -->
        <div class="calc-form">
          <h1 class="calc-title">Lifestyle Arbitrage Calculator</h1>
          <div class="data-badges">
            <span>World Bank PPP 2024</span>
            <span>BEA Regional Data 2024</span>
          </div>

          <!-- Field 1: City -->
          <div class="field-group">
            <label for="citySelect">Current US City</label>
            <select id="citySelect">
              <option value="" disabled selected>Select your city...</option>
              {Object.entries(cityRpp.cities).sort(([a], [b]) => {
                const nameA = a.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                const nameB = b.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                return nameA.localeCompare(nameB);
              }).map(([id, rpp]) => (
                <option value={id} data-rpp={rpp}>
                  {id.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}
                </option>
              ))}
            </select>
          </div>

          <!-- Field 2: Income -->
          <div class="field-group">
            <label for="incomeInput">Annual Income (USD)</label>
            <input
              id="incomeInput"
              type="number"
              placeholder="e.g. 85000"
              min="20000"
              max="500000"
            />
          </div>

          <!-- Field 3: Remote checkbox -->
          <div class="field-group">
            <div class="checkbox-field">
              <input id="remoteCheck" type="checkbox" checked />
              <span>I work remotely and keep my US income after moving</span>
            </div>
          </div>

          <!-- Field 4: Country -->
          <div class="field-group">
            <label for="countrySelect">Target Country</label>
            <select id="countrySelect">
              <option value="" disabled selected>Select destination...</option>
              <option value="AL">Albania</option>
              <option value="AR">Argentina</option>
              <option value="AT">Austria</option>
              <option value="AU">Australia</option>
              <option value="BE">Belgium</option>
              <option value="BG">Bulgaria</option>
              <option value="BR">Brazil</option>
              <option value="CL">Chile</option>
              <option value="CN">China</option>
              <option value="CO">Colombia</option>
              <option value="CR">Costa Rica</option>
              <option value="HR">Croatia</option>
              <option value="CZ">Czech Republic</option>
              <option value="DK">Denmark</option>
              <option value="EC">Ecuador</option>
              <option value="EG">Egypt</option>
              <option value="FI">Finland</option>
              <option value="FR">France</option>
              <option value="GE">Georgia</option>
              <option value="DE">Germany</option>
              <option value="GR">Greece</option>
              <option value="HU">Hungary</option>
              <option value="IS">Iceland</option>
              <option value="IN">India</option>
              <option value="ID">Indonesia</option>
              <option value="IE">Ireland</option>
              <option value="IT">Italy</option>
              <option value="JP">Japan</option>
              <option value="KE">Kenya</option>
              <option value="MY">Malaysia</option>
              <option value="MX">Mexico</option>
              <option value="MA">Morocco</option>
              <option value="NL">Netherlands</option>
              <option value="NZ">New Zealand</option>
              <option value="NO">Norway</option>
              <option value="PA">Panama</option>
              <option value="PE">Peru</option>
              <option value="PH">Philippines</option>
              <option value="PL">Poland</option>
              <option value="PT">Portugal</option>
              <option value="QA">Qatar</option>
              <option value="RO">Romania</option>
              <option value="SA">Saudi Arabia</option>
              <option value="RS">Serbia</option>
              <option value="SG">Singapore</option>
              <option value="KR">South Korea</option>
              <option value="ES">Spain</option>
              <option value="LK">Sri Lanka</option>
              <option value="SE">Sweden</option>
              <option value="CH">Switzerland</option>
              <option value="TH">Thailand</option>
              <option value="AE">United Arab Emirates</option>
              <option value="GB">United Kingdom</option>
              <option value="VN">Vietnam</option>
            </select>
          </div>

          <button id="calcBtn" class="btn-pill btn-pill-primary">Calculate My Savings →</button>

          <div id="loadingState" style="display:none; text-align:center; padding:16px;">
            <p style="color:#475569;">Fetching live World Bank PPP data...</p>
          </div>

          <div id="errorState" style="display:none; text-align:center; padding:16px;">
            <p style="color:#DC2626;">Could not fetch data. Please try again.</p>
          </div>

          <p class="disclaimer">
            Based on World Bank PPP 2024 and BEA Regional Price Parities 2024.
            Estimates may vary 15-25% from actual costs.
          </p>
        </div>

        <!-- RIGHT COLUMN: Results -->
        <div class="calc-results">

          <div id="resultsEmpty">
            <div class="empty-icon">→</div>
            <p style="color:#94A3B8; font-size:15px; margin-top:24px;">
              Enter your details and click Calculate to see your personalized savings report
            </p>
          </div>

          <div id="resultsData" style="display:none;">
            <div class="results-stack">

              <!-- OVERALL SCORE CARD -->
              <div class="result-card result-card-score animate-card">
                <span class="result-label">Overall Score</span>
                <div class="score-display">
                  <div class="score-grade" id="scoreGrade">-</div>
                  <div class="score-details">
                    <div class="score-percent" id="scorePercent">-</div>
                    <div class="score-verdict" id="scoreVerdict">-</div>
                  </div>
                </div>
              </div>

              <!-- SAVINGS CARD -->
              <div class="result-card result-card-savings animate-card">
                <span class="result-label">Annual Savings</span>
                <p id="annualSavings" class="result-value">-</p>
                <p id="monthlySavings" class="result-sub">-</p>
              </div>

              <!-- PURCHASING POWER CARD -->
              <div class="result-card animate-card">
                <span class="result-label">Purchasing Power</span>
                <p id="purchasingPower" class="result-multiplier">-</p>
                <p id="purchasingPowerSub" class="result-sub">-</p>
              </div>

              <!-- YEARS TO FIRE CARD -->
              <div class="result-card animate-card">
                <span class="result-label">Years to Financial Independence</span>
                <p id="yearsToFire" class="result-fire">-</p>
                <p class="result-sub">Based on 25x annual expenses (FIRE method)</p>
              </div>

              <!-- QUALITY OF LIFE CARD -->
              <div class="result-card animate-card">
                <span class="result-label">Quality of Life</span>
                <div class="quality-grid">
                  <div class="quality-item">
                    <div class="quality-row">
                      <span class="progress-label">Safety</span>
                      <span class="progress-score" id="safetyScore">-</span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-bar bar-safety" id="safetyBar"></div>
                    </div>
                  </div>
                  <div class="quality-item">
                    <div class="quality-row">
                      <span class="progress-label">Healthcare</span>
                      <span class="progress-score" id="healthScore">-</span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-bar bar-health" id="healthBar"></div>
                    </div>
                  </div>
                  <div class="quality-item">
                    <div class="quality-row">
                      <span class="progress-label">Happiness</span>
                      <span class="progress-score" id="happinessScore">-</span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-bar bar-happiness" id="happinessBar"></div>
                    </div>
                  </div>
                  <div class="quality-item">
                    <div class="quality-row">
                      <span class="progress-label">Pollution</span>
                      <span class="progress-score" id="pollutionScore">-</span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-bar bar-pollution" id="pollutionBar"></div>
                    </div>
                  </div>
                  <div class="quality-item">
                    <div class="quality-row">
                      <span class="progress-label">Internet</span>
                      <span class="progress-score" id="internetScore">-</span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-bar bar-internet" id="internetBar"></div>
                    </div>
                  </div>
                  <div class="quality-item">
                    <div class="quality-row">
                      <span class="progress-label">Traffic</span>
                      <span class="progress-score" id="trafficScore">-</span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-bar bar-traffic" id="trafficBar"></div>
                    </div>
                  </div>
                  <div class="quality-item">
                    <div class="quality-row">
                      <span class="progress-label">Unemployment</span>
                      <span class="progress-score" id="unempScore">-</span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-bar bar-unemp" id="unempBar"></div>
                    </div>
                  </div>
                  <div class="quality-item">
                    <div class="quality-row">
                      <span class="progress-label">GDP Growth</span>
                      <span class="progress-score" id="gdpScore">-</span>
                    </div>
                    <div class="progress-track">
                      <div class="progress-bar bar-gdp" id="gdpBar"></div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- AI Analysis temporarily disabled -->
              <!-- AI ANALYSIS CARD -->
              <div class="result-card ai-card animate-card" id="aiAnalysis" style="display:none">
                <span class="result-label">Relocation Analysis</span>
                <div id="aiAnalysisText" class="ai-text"></div>
              </div>

              <!-- DATA SOURCES CARD -->
              <div class="result-card sources-card animate-card">
                <p class="sources-title">Data Sources</p>
                <div class="sources-grid">
                  <a href="https://numbeo.com" target="_blank" class="source-badge">
                    <span class="source-icon">🔒</span>
                    <div>
                      <span class="source-name">Numbeo</span>
                      <span class="source-desc">Safety, Healthcare, Pollution, Traffic — latest available</span>
                    </div>
                  </a>
                  <a href="https://data.worldbank.org" target="_blank" class="source-badge">
                    <span class="source-icon">🏛️</span>
                    <div>
                      <span class="source-name">World Bank</span>
                      <span class="source-desc">Unemployment, GDP Growth — latest available</span>
                    </div>
                  </a>
                  <a href="https://ourworldindata.org" target="_blank" class="source-badge">
                    <span class="source-icon">😊</span>
                    <div>
                      <span class="source-name">Our World in Data / WHR</span>
                      <span class="source-desc">Happiness scores — latest available</span>
                    </div>
                  </a>
                  <a href="https://en.wikipedia.org/wiki/List_of_countries_by_Internet_connection_speeds" target="_blank" class="source-badge">
                    <span class="source-icon">⚡</span>
                    <div>
                      <span class="source-name">Speedtest Global Index</span>
                      <span class="source-desc">Internet speeds — latest available</span>
                    </div>
                  </a>
                  <a href="https://www.bea.gov" target="_blank" class="source-badge">
                    <span class="source-icon">🏙️</span>
                    <div>
                      <span class="source-name">U.S. Bureau of Economic Analysis</span>
                      <span class="source-desc">City cost of living — latest available</span>
                    </div>
                  </a>
                  <a href="https://data.worldbank.org/indicator/PA.NUS.PRVT.PP" target="_blank" class="source-badge">
                    <span class="source-icon">🌐</span>
                    <div>
                      <span class="source-name">World Bank PPP</span>
                      <span class="source-desc">Purchasing power — live data</span>
                    </div>
                  </a>
                </div>
              </div>

              <!-- SHARE CARD -->
              <div class="result-card animate-card">
                <p class="result-sub" style="margin-bottom:12px">Share your result</p>
                <div class="share-buttons">
                  <button id="shareBtn" class="btn-outline">Share on X</button>
                  <button id="copyBtn" class="btn-outline">Copy Result</button>
                </div>
              </div>

            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <script id="quality-data" type="application/json" set:html={JSON.stringify(qualityScores.countries)} />
  <script id="city-rpp-data" type="application/json" set:html={JSON.stringify(cityRpp.cities)} />

</BaseLayout>

<script>
  const QUALITY = JSON.parse(
    document.getElementById('quality-data')!.textContent!
  );
  const CITY_RPP = JSON.parse(
    document.getElementById('city-rpp-data')!.textContent!
  );

  const COUNTRY_SLUGS: Record<string, string> = {
    "PT": "portugal",  "ES": "spain",       "MX": "mexico",
    "DE": "germany",   "IT": "italy",        "GR": "greece",
    "CR": "costa-rica","PA": "panama",       "TH": "thailand",
    "MY": "malaysia",  "ID": "indonesia",    "CO": "colombia",
    "HR": "croatia",   "CZ": "czech-republic","PL": "poland",
    "HU": "hungary",   "RO": "romania",      "BG": "bulgaria",
    "VN": "vietnam",   "JP": "japan",        "KR": "south-korea",
    "AU": "australia", "NZ": "new-zealand",  "CA": "canada",
    "IE": "ireland",   "NL": "netherlands",  "FR": "france",
    "AR": "argentina", "EC": "ecuador",      "MA": "morocco",
    "AL": "albania",   "AT": "austria",      "BE": "belgium",
    "BR": "brazil",    "CL": "chile",        "CN": "china",
    "DK": "denmark",   "EG": "egypt",        "FI": "finland",
    "GE": "georgia",   "IS": "iceland",      "IN": "india",
    "KE": "kenya",     "NO": "norway",       "PE": "peru",
    "PH": "philippines","QA": "qatar",       "SA": "saudi-arabia",
    "RS": "serbia",    "SG": "singapore",    "LK": "sri-lanka",
    "SE": "sweden",    "CH": "switzerland",  "AE": "united-arab-emirates",
    "GB": "united-kingdom",
  };

  const citySelect    = document.getElementById('citySelect');
  const incomeInput   = document.getElementById('incomeInput');
  const remoteCheck   = document.getElementById('remoteCheck');
  const countrySelect = document.getElementById('countrySelect');
  const calcBtn       = document.getElementById('calcBtn');
  const loadingState      = document.getElementById('loadingState');
  const errorState        = document.getElementById('errorState');
  const resultsEmpty      = document.getElementById('resultsEmpty');
  const resultsData       = document.getElementById('resultsData');
  const annualSavingsEl   = document.getElementById('annualSavings');
  const monthlySavingsEl  = document.getElementById('monthlySavings');
  const purchasingPowerEl    = document.getElementById('purchasingPower');
  const purchasingPowerSubEl = document.getElementById('purchasingPowerSub');
  const yearsToFireEl     = document.getElementById('yearsToFire');
  const shareBtn      = document.getElementById('shareBtn');
  const copyBtn       = document.getElementById('copyBtn');

  function getCached(key) {
    try {
      const item = sessionStorage.getItem(key);
      if (!item) return null;
      const { value, expires } = JSON.parse(item);
      if (Date.now() > expires) {
        sessionStorage.removeItem(key);
        return null;
      }
      return value;
    } catch { return null; }
  }

  function setCache(key, value, ttlMs) {
    try {
      sessionStorage.setItem(key, JSON.stringify({
        value,
        expires: Date.now() + ttlMs
      }));
    } catch {}
  }

  function calculateOverallScore(quality) {
    const weights = {
      safety: 0.25,
      healthcare: 0.15,
      happiness: 0.15,
      gdpGrowth: 0.15,
      pollution: 0.10,
      unemployment: 0.10,
      internet: 0.05,
      traffic: 0.05
    };

    let totalScore = 0;
    let totalWeight = 0;

    for (const [metric, weight] of Object.entries(weights)) {
      const score = quality[metric];
      if (score !== null && score !== undefined) {
        totalScore += score * weight;
        totalWeight += weight;
      }
    }

    // totalScore is already weighted average of scores 1-10
    // Convert to percentage: score of 10 = 100%
    const weightedAverage = totalWeight > 0
      ? totalScore / totalWeight
      : 0;

    const percent = Math.round(weightedAverage * 10);

    let grade, verdict;
    if (percent >= 85) { grade = 'A'; verdict = 'Excellent destination'; }
    else if (percent >= 70) { grade = 'B'; verdict = 'Good destination'; }
    else if (percent >= 55) { grade = 'C'; verdict = 'Average destination'; }
    else if (percent >= 40) { grade = 'D'; verdict = 'Below average'; }
    else { grade = 'F'; verdict = 'Poor destination'; }

    return { percent, grade, verdict };
  }

  async function generateAIAnalysis(params) {
    const { cityName, countryName, income, annualSavings,
            adjustedMultiplier, yearsToFire, quality,
            isRemote, overallScore } = params;

    const prompt = `You are an expat advisor who lived
in many countries. Write a 120-word insider assessment
for an American moving from ${cityName} to ${countryName}.

Rules:
- NEVER mention scores, percentages, or numbers
  from the data provided
- Focus ONLY on practical facts not visible in charts:
  visa situation, cultural adjustment, language barrier,
  expat community size, bureaucracy, local lifestyle,
  hidden costs, seasonal considerations
- Compare specifically to ${cityName} lifestyle
- Be honest about real challenges Americans face there
- One specific pro and one specific con that surprises people
- End with one actionable first step
- Flowing prose, no bullet points, no headers
- No em dashes, no AI phrases like "it is worth noting"
- Write like a friend who lived there, not a travel brochure
- Use "you" throughout`;

    const response = await fetch('/api/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        messages: [{ role: 'user', content: prompt }]
      })
    });

    const data = await response.json();
    return data.content[0].text;
  }

  calcBtn.addEventListener('click', async () => {
    const cityId   = citySelect.value;
    const income   = parseInt(incomeInput.value);
    const isRemote = remoteCheck.checked;
    const iso2     = countrySelect.value;

    if (!cityId || !income || !iso2) {
      alert('Please fill in all fields');
      return;
    }
    if (income < 20000 || income > 500000) {
      alert('Please enter income between $20,000 and $500,000');
      return;
    }

    loadingState.style.display = 'block';
    resultsEmpty.style.display = 'none';
    errorState.style.display   = 'none';
    calcBtn.disabled           = true;

    const COUNTRY_CURRENCIES = {
      "PT":"EUR","ES":"EUR","MX":"MXN","DE":"EUR",
      "IT":"EUR","GR":"EUR","CR":"CRC","PA":"USD",
      "TH":"THB","MY":"MYR","ID":"IDR","CO":"COP",
      "HR":"EUR","CZ":"CZK","PL":"PLN","HU":"HUF",
      "RO":"RON","BG":"BGN","VN":"VND","JP":"JPY",
      "KR":"KRW","AU":"AUD","NZ":"NZD","CA":"CAD",
      "IE":"EUR","NL":"EUR","FR":"EUR","AR":"ARS",
      "EC":"USD","MA":"MAD",
      "AL":"ALL","AT":"EUR","BE":"EUR","BR":"BRL",
      "CL":"CLP","CN":"CNY","DK":"DKK","EG":"EGP",
      "FI":"EUR","GE":"GEL","IS":"ISK","IN":"INR",
      "KE":"KES","NO":"NOK","PE":"PEN","PH":"PHP",
      "QA":"QAR","SA":"SAR","RS":"RSD","SG":"SGD",
      "LK":"LKR","SE":"SEK","CH":"CHF","AE":"AED",
      "GB":"GBP"
    };

    try {
      const currency    = COUNTRY_CURRENCIES[iso2];
      const cityRPP     = CITY_RPP[cityId];
      const countryName = countrySelect.options[countrySelect.selectedIndex].text;
      const cityName    = citySelect.options[citySelect.selectedIndex].text;

      // Fetch World Bank PPP and exchange rate in parallel
      // Cache keys
      const pppCacheKey = `ppp_${iso2}`;
      const fxCacheKey = 'fx_usd';

      // Try cache first
      let countryPPP = getCached(pppCacheKey);
      let exchangeRate = getCached(fxCacheKey + '_' + currency);

      // Fetch only what's missing
      const fetchPromises = [];
      if (!countryPPP) {
        fetchPromises.push(
          fetch(`https://api.worldbank.org/v2/country/${iso2}/indicator/PA.NUS.PRVT.PP?format=json&mrv=1&per_page=1`)
            .then(r => r.json())
            .then(data => {
              countryPPP = data[1][0].value;
              if (!countryPPP) throw new Error('No PPP data available');
              setCache(pppCacheKey, countryPPP, 24 * 60 * 60 * 1000); // 24h
            })
        );
      }
      if (!exchangeRate && currency !== 'USD') {
        fetchPromises.push(
          fetch('https://open.er-api.com/v6/latest/USD')
            .then(r => r.json())
            .then(data => {
              const rates = data.rates;
              // Cache all rates at once
              Object.entries(rates).forEach(([cur, rate]) => {
                setCache(fxCacheKey + '_' + cur, rate, 24 * 60 * 60 * 1000);
              });
              exchangeRate = rates[currency];
              if (!exchangeRate) throw new Error('No exchange rate for ' + currency);
            })
        );
      } else if (currency === 'USD') {
        exchangeRate = 1;
      }

      if (fetchPromises.length > 0) {
        await Promise.all(fetchPromises);
      }

      // Price level ratio: how expensive country is vs US average (1.0 = same as US)
      // countryPPP is LCU per international dollar
      // exchangeRate is LCU per USD
      // priceLevel = countryPPP / exchangeRate
      const priceLevel = countryPPP / exchangeRate;

      // How much further money goes: 1 / priceLevel
      // Adjusted for city being more/less expensive than US average
      const adjustedMultiplier = (1 / priceLevel) * cityRPP;

      // Equivalent income needed in target country
      const equivalentIncome = Math.round(income / adjustedMultiplier);

      let annualSavings  = 0;
      let monthlySavings = 0;
      if (isRemote) {
        annualSavings  = income - equivalentIncome;
        monthlySavings = Math.round(annualSavings / 12);
      }

      // FIRE: 25x annual expenses
      const fireTarget     = equivalentIncome * 25;
      const yearsToFireNum = (isRemote && annualSavings > 0)
        ? Math.round(fireTarget / annualSavings)
        : null;

      // Update results
      if (isRemote && annualSavings > 0) {
        annualSavingsEl.textContent  = '$' + annualSavings.toLocaleString();
        annualSavingsEl.style.color  = '#16A34A';
        monthlySavingsEl.textContent = 'You save $' + monthlySavings.toLocaleString() + ' every month';
      } else if (isRemote && annualSavings <= 0) {
        annualSavingsEl.textContent  = 'Higher cost destination';
        annualSavingsEl.style.color  = '#DC2626';
        monthlySavingsEl.textContent = 'Cost of living higher than ' + cityName;
      } else {
        annualSavingsEl.textContent  = '$' + equivalentIncome.toLocaleString();
        annualSavingsEl.style.color  = '#2563EB';
        monthlySavingsEl.textContent = 'Equivalent income needed in ' + countryName;
      }

      purchasingPowerEl.textContent    = adjustedMultiplier.toFixed(2) + 'x';
      purchasingPowerSubEl.textContent = 'Your $' + income.toLocaleString() + ' from ' + cityName + ' has the purchasing power of $' + Math.round(income * adjustedMultiplier).toLocaleString() + ' in ' + countryName;

      if (!isRemote) {
        yearsToFireEl.textContent = 'Enable remote income to calculate';
      } else if (annualSavings <= 0) {
        yearsToFireEl.textContent = 'Costs more than your origin city';
      } else if (yearsToFireNum) {
        yearsToFireEl.textContent = yearsToFireNum + ' years';
      } else {
        yearsToFireEl.textContent = 'N/A';
      }

      const slug = COUNTRY_SLUGS[iso2];
      const q    = QUALITY[slug];

      const overallScore = calculateOverallScore(q);

      document.getElementById('scoreGrade').textContent   = overallScore.grade;
      document.getElementById('scorePercent').textContent = overallScore.percent + '%';
      document.getElementById('scoreVerdict').textContent = overallScore.verdict;

      const gradeEl = document.getElementById('scoreGrade');
      gradeEl.className = 'score-grade grade-' + overallScore.grade;

      const metrics = [
        ['safety',       'safetyScore',    'safetyBar'],
        ['healthcare',   'healthScore',    'healthBar'],
        ['happiness',    'happinessScore', 'happinessBar'],
        ['pollution',    'pollutionScore', 'pollutionBar'],
        ['internet',     'internetScore',  'internetBar'],
        ['traffic',      'trafficScore',   'trafficBar'],
        ['unemployment', 'unempScore',     'unempBar'],
        ['gdpGrowth',    'gdpScore',       'gdpBar']
      ];

      metrics.forEach(([key, scoreId, barId]) => {
        const val = q[key];
        if (val !== null && val !== undefined) {
          document.getElementById(scoreId).textContent = val + '/10';
          setTimeout(() => {
            document.getElementById(barId).style.width = (val * 10) + '%';
          }, 300);
        }
      });

      const shareText = (isRemote && annualSavings > 0)
        ? 'Moving from ' + cityName + ' to ' + countryName + ' could save me $' + annualSavings.toLocaleString() + '/year. Calculate yours: leavingamerica.co/tools/salary'
        : 'My $' + income.toLocaleString() + ' salary has ' + adjustedMultiplier.toFixed(1) + 'x more purchasing power in ' + countryName + '. Calculate yours: leavingamerica.co/tools/salary';

      shareBtn.onclick = () => window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(shareText));
      copyBtn.onclick  = () => navigator.clipboard.writeText(shareText);

      loadingState.style.display  = 'none';
      resultsData.style.display   = 'block';
      resultsData.style.animation = 'fadeIn 0.4s ease';

      const cards = document.querySelectorAll('.animate-card');
      cards.forEach((card, i) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        setTimeout(() => {
          card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        }, i * 100);
      });

      /* TEMPORARILY DISABLED
      const aiCard = document.getElementById('aiAnalysis');
      const aiText = document.getElementById('aiAnalysisText');
      aiCard.style.display = 'block';
      aiText.innerHTML = '<p style="color:#6366F1;font-size:13px">Generating analysis...</p>';

      generateAIAnalysis({
        cityName,
        countryName,
        income,
        annualSavings: isRemote ? annualSavings : 0,
        adjustedMultiplier,
        yearsToFire: yearsToFireNum,
        quality: q,
        isRemote,
        overallScore
      }).then(text => {
        const formatted = text
          .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
          .split(/\n\n+/)
          .filter(p => p.trim())
          .map(p => '<p>' + p.trim() + '</p>')
          .join('');
        aiText.innerHTML = formatted;
      }).catch(() => {
        aiCard.style.display = 'none';
      });
      */

    } catch (err) {
      console.error(err);
      loadingState.style.display = 'none';
      errorState.style.display   = 'block';
    } finally {
      calcBtn.disabled = false;
    }
  });

  (async function prefetch() {
    try {
      // Check if already cached
      const testPPP = getCached('ppp_PL');
      const testFX = getCached('fx_usd_EUR');

      const fetchList = [];

      // Prefetch all PPP data in one request
      if (!testPPP) {
        const allISO2 = Object.keys(COUNTRY_CURRENCIES).join(';');
        fetchList.push(
          fetch(`https://api.worldbank.org/v2/country/${allISO2}/indicator/PA.NUS.PRVT.PP?format=json&mrv=1&per_page=60`)
            .then(r => r.json())
            .then(data => {
              if (data[1]) {
                data[1].forEach(item => {
                  if (item.value) {
                    setCache('ppp_' + item.country.id, item.value, 24 * 60 * 60 * 1000);
                  }
                });
              }
            })
        );
      }

      // Prefetch exchange rates
      if (!testFX) {
        fetchList.push(
          fetch('https://open.er-api.com/v6/latest/USD')
            .then(r => r.json())
            .then(data => {
              Object.entries(data.rates).forEach(([cur, rate]) => {
                setCache('fx_usd_' + cur, rate, 24 * 60 * 60 * 1000);
              });
            })
        );
      }

      if (fetchList.length > 0) {
        await Promise.all(fetchList);
        console.log('Data prefetched and cached');
      }
    } catch(e) {
      // Silent fail
    }
  })();
</script>

